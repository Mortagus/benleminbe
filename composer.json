{
    "name": "mortagus/benleminbe",
    "description": "Code source de mon site web perso, pour avoir une présence en ligne professionnelle ainsi que pour développer des outils à moi",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0",
        "symfony/asset": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/console": "^8.0",
        "symfony/asset-mapper": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/apache-pack": "^1.0",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-libxml": "*",
        "symfony/security-bundle": "^8.0",
        "symfony/security-csrf": "^8.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Benjamin Lemin",
            "email": "benjamin@lemin.be"
        }
    ],
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "css:format": "npm run format:css",
        "css:lint": "npm run lint:css",
        "dnd:bestiary:generate": "php tools/dnd/complete_monster_extractor.php",
        "dnd:bestiary:test": "php tools/dnd/validate_bestiary.php",
        "js:test": "npm run test:js"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.67"
    }
}
