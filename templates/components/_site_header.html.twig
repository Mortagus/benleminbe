{# Components - _site_header.html.twig #}

{% trans_default_domain 'layout' %}

<header class="site-header" data-site-header>
    <div class="site-header__inner">
        <a href="{{ path('app_home', { _locale: app.request.locale }) }}" class="site-header__brand">
            Benjamin Lemin
        </a>

        <button
            type="button"
            class="site-header__menu-toggle"
            data-menu-toggle
            aria-controls="site-header-nav"
            aria-expanded="false"
            aria-label="{{ 'header.navigation.open_menu'|trans }}"
            data-label-open="{{ 'header.navigation.open_menu'|trans }}"
            data-label-close="{{ 'header.navigation.close_menu'|trans }}"
        >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </button>

        <nav
            id="site-header-nav"
            class="site-header__nav"
            data-site-nav
            aria-label="{{ 'header.navigation.label'|trans }}"
        >
            <a href="{{ path('app_home', { _locale: app.request.locale }) }}"
               class="site-header__link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">
                {{ 'header.navigation.home'|trans }}
            </a>

            <a href="{{ path('app_projects_index', { _locale: app.request.locale }) }}"
               class="site-header__link {{ app.request.attributes.get('_route') starts with 'app_projects' ? 'active' : '' }}">
                {{ 'header.navigation.projects'|trans }}
            </a>

            <a href="{{ path('app_experiences_index', { _locale: app.request.locale }) }}"
               class="site-header__link {{ app.request.attributes.get('_route') starts with 'app_experiences' ? 'active' : '' }}">
                {{ 'header.navigation.experiences'|trans }}
            </a>

            <a href="{{ path('app_skills', { _locale: app.request.locale }) }}"
               class="site-header__link {{ app.request.attributes.get('_route') == 'app_skills' ? 'active' : '' }}">
                {{ 'header.navigation.skills'|trans }}
            </a>

            <a href="{{ path('app_about', { _locale: app.request.locale }) }}"
               class="site-header__link {{ app.request.attributes.get('_route') == 'app_about' ? 'active' : '' }}">
                {{ 'header.navigation.about'|trans }}
            </a>

            <a href="{{ path('app_contact', { _locale: app.request.locale }) }}"
               class="site-header__link {{ app.request.attributes.get('_route') == 'app_contact' ? 'active' : '' }}">
                {{ 'header.navigation.contact'|trans }}
            </a>
        </nav>

        <div class="site-header__actions">
            {% include 'components/_lang_switcher.html.twig' %}
            {% include 'components/_theme_switcher.html.twig' %}
        </div>
    </div>
</header>
