{% extends 'base.html.twig' %}

{% trans_default_domain 'experiences' %}

{% block title %}{{ experienceData.metaTitle }}{% endblock %}
{% block meta_description %}{{ experienceData.summary|strip_keyword_highlights }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_experience_detail']) }}{% endblock %}

{% block body %}
    <main class="experience-detail-page">
        <nav class="experience-detail-navigation experience-detail-navigation--top" aria-label="{{ 'experiences.detail.breadcrumb_label'|trans }}">
            <a class="experience-detail-navigation__link experience-detail-navigation__link--back" href="{{ path('app_experiences_index', { _locale: app.request.locale }) }}">
                {{ 'experiences.detail.back_to_list'|trans }}
            </a>
        </nav>

        <header class="experience-detail-hero">
            <p class="experience-detail-hero__eyebrow">
                {{ 'experiences.detail.eyebrow'|trans }}
            </p>

            <h1>{{ experienceData.company }}</h1>

            <p class="experience-detail-hero__lead">
                {{ experienceData.role }}
            </p>

            <ul class="experience-detail-meta">
                <li>
                    <strong>{{ 'experiences.detail.period_label'|trans }}</strong>
                    <span>{{ experienceData.period }}</span>
                </li>
                <li>
                    <strong>{{ 'experiences.detail.role_label'|trans }}</strong>
                    <span>{{ experienceData.role }}</span>
                </li>
                <li>
                    <strong>{{ 'experiences.detail.main_technologies_label'|trans }}</strong>
                    <span>{{ experienceData.technologies|join(', ') }}</span>
                </li>
            </ul>
        </header>

        <button class="content-toc-toggle"
                type="button"
                data-content-toc-toggle
                aria-controls="experience-toc"
                aria-expanded="false">
            <span class="content-toc-toggle__icon" aria-hidden="true"></span>
            <span class="content-toc-toggle__label">{{ 'experiences.detail.toc_title'|trans }}</span>
        </button>

        <nav id="experience-toc" class="content-toc" data-content-toc aria-labelledby="experience-toc-title">
            <h2 id="experience-toc-title">{{ 'experiences.detail.toc_title'|trans }}</h2>

            <ol>
                <li>
                    <a href="#overview">{{ 'experiences.detail.summary_title'|trans }}</a>
                </li>
                {% if experienceData.context is not empty %}
                    <li>
                        <a href="#context">{{ 'experiences.detail.context_title'|trans }}</a>
                    </li>
                {% endif %}
                {% if experienceData.responsibilities is not empty %}
                    <li>
                        <a href="#responsibilities">{{ 'experiences.detail.responsibilities_title'|trans }}</a>
                    </li>
                {% endif %}
                {% if experienceData.technologies is not empty %}
                    <li>
                        <a href="#technologies">{{ 'experiences.detail.technologies_title'|trans }}</a>
                    </li>
                {% endif %}
                {% if associatedProjects is defined and associatedProjects is not empty %}
                    <li>
                        <a href="#associated-projects">{{ 'experiences.detail.associated_projects_title'|trans }}</a>
                    </li>
                {% endif %}
                {% if experienceData.takeaways is not empty %}
                    <li>
                        <a href="#takeaways">{{ 'experiences.detail.takeaways_title'|trans }}</a>
                    </li>
                {% endif %}
            </ol>
        </nav>

        <section id="overview" class="experience-detail-highlight">
            <h2>{{ 'experiences.detail.summary_title'|trans }}</h2>
            <p>{{ experienceData.summary|highlight_keywords }}</p>
        </section>

        {% if experienceData.context is not empty %}
            <section id="context" class="experience-detail-section">
                <h2>{{ 'experiences.detail.context_title'|trans }}</h2>

                {% for paragraph in experienceData.context %}
                    <p>{{ paragraph|highlight_keywords }}</p>
                {% endfor %}
            </section>
        {% endif %}

        {% if experienceData.responsibilities is not empty %}
            <section id="responsibilities" class="experience-detail-section">
                <h2>{{ 'experiences.detail.responsibilities_title'|trans }}</h2>

                <ul>
                    {% for responsibility in experienceData.responsibilities %}
                        <li>{{ responsibility|highlight_keywords }}</li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}

        {% if experienceData.technologies is not empty %}
            <section id="technologies" class="experience-detail-section">
                <h2>{{ 'experiences.detail.technologies_title'|trans }}</h2>

                <ul class="experience-detail-technologies">
                    {% for technology in experienceData.technologies %}
                        <li>{{ technology }}</li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}

        {% if associatedProjects is defined and associatedProjects is not empty %}
            <section id="associated-projects" class="experience-detail-section">
                <h2>{{ 'experiences.detail.associated_projects_title'|trans }}</h2>
                <p>{{ 'experiences.detail.associated_projects_description'|trans }}</p>

                <div class="experience-associated-projects">
                    {% for project in associatedProjects %}
                        <a class="experience-associated-project-card" href="{{ path('app_projects_show', {
                            _locale: app.request.locale,
                            project: project.key
                        }) }}">
                            <strong>{{ project.title }}</strong>
                            <span>{{ project.description|highlight_keywords }}</span>
                            <span class="experience-associated-project-card__link">
                                {{ 'experiences.detail.associated_project_link'|trans }}
                            </span>
                        </a>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if experienceData.takeaways is not empty %}
            <section id="takeaways" class="experience-detail-highlight">
                <h2>{{ 'experiences.detail.takeaways_title'|trans }}</h2>

                <ul>
                    {% for takeaway in experienceData.takeaways %}
                        <li>{{ takeaway|highlight_keywords }}</li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}

        <nav class="experience-detail-navigation" aria-label="{{ 'experiences.detail.pagination_label'|trans }}">
            <a class="experience-detail-navigation__link experience-detail-navigation__link--back" href="{{ path('app_experiences_index', { _locale: app.request.locale }) }}">
                {{ 'experiences.detail.back_to_list'|trans }}
            </a>

            {% if previousExperience %}
                <a class="experience-detail-navigation__link experience-detail-navigation__link--previous" href="{{ path('app_experiences_show', {
                    _locale: app.request.locale,
                    experience: previousExperience
                }) }}">
                    {{ 'experiences.detail.previous'|trans }}
                </a>
            {% endif %}

            {% if nextExperience %}
                <a class="experience-detail-navigation__link experience-detail-navigation__link--next" href="{{ path('app_experiences_show', {
                    _locale: app.request.locale,
                    experience: nextExperience
                }) }}">
                    {{ 'experiences.detail.next'|trans }}
                </a>
            {% endif %}
        </nav>
    </main>
{% endblock %}
