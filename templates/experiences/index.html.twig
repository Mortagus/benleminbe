{% extends 'base.html.twig' %}

{% trans_default_domain 'experiences' %}

{% block title %}{{ 'experiences.index.meta_title'|trans }}{% endblock %}
{% block meta_description %}{{ 'experiences.index.meta_description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_experiences']) }}{% endblock %}

{% block body %}
    <main class="page page--experiences">
        <section class="page-header">
            <p class="page-header__eyebrow">{{ 'experiences.index.eyebrow'|trans }}</p>
            <h1>{{ 'experiences.index.title'|trans }}</h1>
            <p class="page-header__description">
                {{ 'experiences.index.description'|trans|highlight_keywords }}
            </p>
        </section>

        <section class="experience-summary" aria-labelledby="experience-summary-title">
            <div class="experience-summary__panel card">
                <div class="experience-summary__intro">
                    <p class="experience-summary__eyebrow">{{ 'experiences.index.summary.eyebrow'|trans }}</p>
                    <h2 id="experience-summary-title">{{ 'experiences.index.summary.title'|trans }}</h2>
                    <p>{{ 'experiences.index.summary.lead'|trans|highlight_keywords }}</p>
                </div>

                <div class="experience-summary__facts" role="list" aria-label="{{ 'experiences.index.summary.facts_label'|trans }}">
                    <article class="experience-summary__fact" role="listitem">
                        <strong>{{ 'experiences.index.summary.fact_1.value'|trans }}</strong>
                        <span>{{ 'experiences.index.summary.fact_1.label'|trans }}</span>
                    </article>

                    <article class="experience-summary__fact" role="listitem">
                        <strong>{{ 'experiences.index.summary.fact_2.value'|trans }}</strong>
                        <span>{{ 'experiences.index.summary.fact_2.label'|trans }}</span>
                    </article>

                    <article class="experience-summary__fact" role="listitem">
                        <strong>{{ 'experiences.index.summary.fact_3.value'|trans }}</strong>
                        <span>{{ 'experiences.index.summary.fact_3.label'|trans }}</span>
                    </article>

                    <article class="experience-summary__fact" role="listitem">
                        <strong>{{ 'experiences.index.summary.fact_4.value'|trans }}</strong>
                        <span>{{ 'experiences.index.summary.fact_4.label'|trans }}</span>
                    </article>
                </div>

                <div class="experience-summary__specialties">
                    <h3>{{ 'experiences.index.summary.specialties_title'|trans }}</h3>

                    <ul class="experience-summary__chips" aria-label="{{ 'experiences.index.summary.specialties_title'|trans }}">
                        <li>{{ 'experiences.index.summary.specialty_1'|trans }}</li>
                        <li>{{ 'experiences.index.summary.specialty_2'|trans }}</li>
                        <li>{{ 'experiences.index.summary.specialty_3'|trans }}</li>
                        <li>{{ 'experiences.index.summary.specialty_4'|trans }}</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="experience-list" aria-labelledby="experience-list-title">
            <h2 id="experience-list-title" class="visually-hidden">
                {{ 'experiences.index.list_title'|trans }}
            </h2>

            {% for experience in experiences %}
                {% set translationPrefix = 'experiences.items.' ~ experience.translation_key %}
                {% set listContext = (translationPrefix ~ '.list_context')|trans %}
                {% set listSummary = (translationPrefix ~ '.list_summary')|trans %}
                {% set visibleTechnologies = experience.technologies|slice(0, 3) %}
                {% set remainingTechnologiesCount = experience.technologies|length - visibleTechnologies|length %}

                <a class="experience-card-link"
                   href="{{ path('app_experiences_show', {
                       _locale: app.request.locale,
                       experience: experience.slug
                   }) }}">
                    <article class="experience-card">
                        <header class="experience-card__header">
                            <div>
                                <p class="experience-card__period">
                                    {{ experience.period }}
                                    <span class="experience-card__duration">· {{ experience.duration }}</span>
                                </p>
                                <h3 class="experience-card__title">
                                    {{ (translationPrefix ~ '.company')|trans }}
                                </h3>
                                <p class="experience-card__context">
                                    {{ listContext }}
                                </p>
                                <p class="experience-card__role">
                                    {{ (translationPrefix ~ '.role')|trans }}
                                </p>
                            </div>
                        </header>

                        <p class="experience-card__summary">
                            {{ listSummary|highlight_keywords }}
                        </p>

                        <ul class="experience-card__technologies" aria-label="{{ 'experiences.index.technologies_label'|trans }}">
                            {% for technology in visibleTechnologies %}
                                <li>{{ technology }}</li>
                            {% endfor %}
                            {% if remainingTechnologiesCount > 0 %}
                                <li>{{ 'experiences.index.more_technologies'|trans({ '%count%': remainingTechnologiesCount }) }}</li>
                            {% endif %}
                        </ul>

                        <span class="experience-card__link">
                            {{ 'experiences.index.read_more'|trans }}
                        </span>
                    </article>
                </a>
            {% endfor %}
        </section>
    </main>
{% endblock %}
