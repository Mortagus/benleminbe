{% extends 'base.html.twig' %}

{% trans_default_domain 'experiences' %}

{% block title %}{{ 'experiences.index.meta_title'|trans }}{% endblock %}
{% block meta_description %}{{ 'experiences.index.meta_description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_experiences']) }}{% endblock %}

{% block body %}
    <main class="page page--experiences">
        <section class="page-header">
            <p class="page-header__eyebrow">{{ 'experiences.index.eyebrow'|trans }}</p>
            <h1>{{ 'experiences.index.title'|trans }}</h1>
            <p class="page-header__description">
                {{ 'experiences.index.description'|trans }}
            </p>
        </section>

        <section class="experience-list" aria-labelledby="experience-list-title">
            <h2 id="experience-list-title" class="visually-hidden">
                {{ 'experiences.index.list_title'|trans }}
            </h2>

            {% for experience in experiences %}
                {% set translationPrefix = 'experiences.items.' ~ experience.translation_key %}
                {% set visibleTechnologies = experience.technologies|slice(0, 3) %}
                {% set remainingTechnologiesCount = experience.technologies|length - visibleTechnologies|length %}

                <a class="experience-card-link"
                   href="{{ path('app_experiences_show', {
                       _locale: app.request.locale,
                       experience: experience.slug
                   }) }}">
                    <article class="experience-card">
                        <header class="experience-card__header">
                            <div>
                                <p class="experience-card__period">{{ experience.period }}</p>
                                <h3 class="experience-card__title">
                                    {{ (translationPrefix ~ '.company')|trans }}
                                </h3>
                                <p class="experience-card__role">
                                    {{ (translationPrefix ~ '.role')|trans }}
                                </p>
                            </div>
                        </header>

                        <p class="experience-card__summary">
                            {{ (translationPrefix ~ '.summary')|trans }}
                        </p>

                        <ul class="experience-card__technologies" aria-label="{{ 'experiences.index.technologies_label'|trans }}">
                            {% for technology in visibleTechnologies %}
                                <li>{{ technology }}</li>
                            {% endfor %}
                            {% if remainingTechnologiesCount > 0 %}
                                <li>{{ 'experiences.index.more_technologies'|trans({ '%count%': remainingTechnologiesCount }) }}</li>
                            {% endif %}
                        </ul>

                        <span class="experience-card__link">
                            {{ 'experiences.index.read_more'|trans }}
                        </span>
                    </article>
                </a>
            {% endfor %}
        </section>
    </main>
{% endblock %}
