{% extends 'base.html.twig' %}

{% trans_default_domain 'games' %}

{% block title %}{{ 'simon.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'simon.meta.description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_games_simon']) }}{% endblock %}

{% block body %}
    <main
        class="simon-page"
        data-simon-page
        data-simon-phase="idle"
        data-simon-config="{{ {
            labels: {
                start: 'simon.actions.start'|trans,
                restart: 'simon.actions.restart'|trans,
                status: {
                    idle: 'simon.status.idle'|trans,
                    preparation: 'simon.status.preparation'|trans,
                    demo: 'simon.status.demo'|trans,
                    player: 'simon.status.player'|trans,
                    success: 'simon.status.success'|trans,
                    failure: 'simon.status.failure'|trans,
                },
                audio: {
                    eyebrow: 'simon.audio.eyebrow'|trans,
                    title: 'simon.audio.title'|trans,
                    toggleOn: 'simon.audio.toggle_on'|trans,
                    toggleOff: 'simon.audio.toggle_off'|trans,
                    volumeLabel: 'simon.audio.volume_label'|trans,
                    volumeValue: 'simon.audio.volume_value'|trans,
                    noteDurationLabel: 'simon.audio.note_duration_label'|trans,
                    noteDurationValue: 'simon.audio.note_duration_value'|trans,
                    reverbLabel: 'simon.audio.reverb_label'|trans,
                    reverbValue: 'simon.audio.reverb_value'|trans,
                    active: 'simon.audio.active'|trans,
                    muted: 'simon.audio.muted'|trans,
                    unavailable: 'simon.audio.unavailable'|trans,
                    paletteLabel: 'simon.audio.palette.label'|trans,
                    paletteDescription: 'simon.audio.palette.description'|trans,
                    palettePreview: 'simon.audio.palette.preview'|trans,
                    palettePreviewing: 'simon.audio.palette.previewing'|trans,
                    paletteMuted: 'simon.audio.palette.muted'|trans,
                    paletteUnavailable: 'simon.audio.palette.unavailable'|trans,
                    paletteActive: 'simon.audio.palette.active'|trans,
                    noteSetLabel: 'simon.audio.note_set.label'|trans,
                    noteSetDescription: 'simon.audio.note_set.description'|trans,
                    noteSetActive: 'simon.audio.note_set.active'|trans,
                },
                keyboard: {
                    title: 'simon.keyboard.title'|trans,
                    intro: 'simon.keyboard.intro'|trans,
                    summary: 'simon.keyboard.summary'|trans,
                    idle: 'simon.keyboard.idle'|trans,
                    capture: 'simon.keyboard.capture'|trans,
                    applied: 'simon.keyboard.applied'|trans,
                    duplicate: 'simon.keyboard.duplicate'|trans,
                    invalid: 'simon.keyboard.invalid'|trans,
                    reset: 'simon.keyboard.reset'|trans,
                    actions: {
                        edit: 'simon.keyboard.actions.edit'|trans,
                        reset: 'simon.keyboard.actions.reset'|trans,
                    },
                    zones: {
                        'top-left': 'simon.keyboard.zones.top_left'|trans,
                        'top-right': 'simon.keyboard.zones.top_right'|trans,
                        'bottom-left': 'simon.keyboard.zones.bottom_left'|trans,
                        'bottom-right': 'simon.keyboard.zones.bottom_right'|trans,
                    },
                    padAria: 'simon.keyboard.pad_aria'|trans,
                },
            },
        }|json_encode|e('html_attr') }}"
    >
        <header class="simon-hero">
            <div class="simon-hero__copy">
                <p class="eyebrow">{{ 'simon.hero.eyebrow'|trans }}</p>

                <h1>{{ 'simon.hero.title'|trans }}</h1>

                <p class="simon-hero__intro">
                    {{ 'simon.hero.intro'|trans|highlight_keywords }}
                </p>
            </div>

            <div class="simon-hero__actions">
                <a class="button button-secondary" href="{{ path('app_games_index', { _locale: app.request.locale }) }}">
                    {{ 'simon.actions.back'|trans }}
                </a>
            </div>

            <p class="simon-hero__note">
                {{ 'simon.sound.note'|trans|highlight_keywords }}
            </p>
        </header>

        <section class="content-section" aria-labelledby="simon-board-title">
            <div class="card simon-shell">
                <h2 id="simon-board-title" class="simon-sr-only">{{ 'simon.instructions.title'|trans }}</h2>

                <div class="simon-layout">
                    <div
                        class="simon-stage"
                        data-simon-stage
                        tabindex="-1"
                        aria-label="{{ 'simon.stage.label'|trans }}"
                    >
                        <div
                            class="simon-board"
                            data-simon-board
                            aria-label="{{ 'simon.board.label'|trans }}"
                            aria-describedby="simon-board-title simon-board-help simon-board-note"
                        >
                            <button
                                type="button"
                                class="simon-pad simon-pad--top-left"
                                data-simon-pad="0"
                                data-simon-keyboard-zone="top-left"
                                aria-keyshortcuts="{{ 'simon.keyboard.default_keys.top_left'|trans }}"
                                aria-label="{{ 'simon.board.pads.top_left.aria'|trans }}"
                            >
                                <span class="simon-pad__content">
                                    <span class="simon-pad__key" data-simon-keyboard-key="top-left">{{ 'simon.keyboard.default_keys.top_left'|trans }}</span>
                                    <span class="simon-pad__label">{{ 'simon.board.pads.top_left.label'|trans }}</span>
                                </span>
                            </button>

                            <button
                                type="button"
                                class="simon-pad simon-pad--top-right"
                                data-simon-pad="1"
                                data-simon-keyboard-zone="top-right"
                                aria-keyshortcuts="{{ 'simon.keyboard.default_keys.top_right'|trans }}"
                                aria-label="{{ 'simon.board.pads.top_right.aria'|trans }}"
                            >
                                <span class="simon-pad__content">
                                    <span class="simon-pad__key" data-simon-keyboard-key="top-right">{{ 'simon.keyboard.default_keys.top_right'|trans }}</span>
                                    <span class="simon-pad__label">{{ 'simon.board.pads.top_right.label'|trans }}</span>
                                </span>
                            </button>

                            <button
                                type="button"
                                class="simon-pad simon-pad--bottom-left"
                                data-simon-pad="2"
                                data-simon-keyboard-zone="bottom-left"
                                aria-keyshortcuts="{{ 'simon.keyboard.default_keys.bottom_left'|trans }}"
                                aria-label="{{ 'simon.board.pads.bottom_left.aria'|trans }}"
                            >
                                <span class="simon-pad__content">
                                    <span class="simon-pad__key" data-simon-keyboard-key="bottom-left">{{ 'simon.keyboard.default_keys.bottom_left'|trans }}</span>
                                    <span class="simon-pad__label">{{ 'simon.board.pads.bottom_left.label'|trans }}</span>
                                </span>
                            </button>

                            <button
                                type="button"
                                class="simon-pad simon-pad--bottom-right"
                                data-simon-pad="3"
                                data-simon-keyboard-zone="bottom-right"
                                aria-keyshortcuts="{{ 'simon.keyboard.default_keys.bottom_right'|trans }}"
                                aria-label="{{ 'simon.board.pads.bottom_right.aria'|trans }}"
                            >
                                <span class="simon-pad__content">
                                    <span class="simon-pad__key" data-simon-keyboard-key="bottom-right">{{ 'simon.keyboard.default_keys.bottom_right'|trans }}</span>
                                    <span class="simon-pad__label">{{ 'simon.board.pads.bottom_right.label'|trans }}</span>
                                </span>
                            </button>

                            <div class="simon-board__core">
                                <div class="simon-board__metric simon-board__metric--status">
                                    <span class="simon-board__metric-label">{{ 'simon.metrics.status'|trans }}</span>
                                    <strong data-simon-status aria-live="polite">{{ 'simon.status.idle'|trans }}</strong>
                                </div>

                                <div class="simon-board__metric">
                                    <span class="simon-board__metric-label">{{ 'simon.metrics.level'|trans }}</span>
                                    <strong data-simon-level>0</strong>
                                </div>

                                <div class="simon-board__metric">
                                    <span class="simon-board__metric-label">{{ 'simon.metrics.best'|trans }}</span>
                                    <strong data-simon-best>0</strong>
                                </div>
                            </div>
                        </div>

                        <div class="simon-stage__actions">
                            <button type="button" class="button" data-simon-start>
                                {{ 'simon.actions.start'|trans }}
                            </button>

                            <button
                                type="button"
                                class="button button-secondary simon-audio__toggle"
                                data-simon-sound
                                aria-pressed="true"
                                aria-label="{{ 'simon.audio.toggle_on'|trans }}"
                                title="{{ 'simon.audio.toggle_on'|trans }}"
                            >
                                <span class="simon-audio__icon simon-audio__icon--on" data-simon-sound-icon="on" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                        <path d="M5 10v4h4l5 4V6l-5 4H5z" fill="currentColor"/>
                                        <path d="M16.5 8.5a4 4 0 0 1 0 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    </svg>
                                </span>

                                <span class="simon-audio__icon simon-audio__icon--off" data-simon-sound-icon="off" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                        <path d="M5 10v4h4l5 4V6l-5 4H5z" fill="currentColor"/>
                                        <path d="M16 8l5 5m0-5-5 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    </svg>
                                </span>
                            </button>
                        </div>
                    </div>

                    <aside class="simon-sidebar">
                        <details class="simon-disclosure simon-disclosure--audio">
                            <summary class="simon-disclosure__summary">
                                <span class="simon-disclosure__text">
                                    <span class="eyebrow">{{ 'simon.audio.eyebrow'|trans }}</span>
                                    <span class="simon-disclosure__title">{{ 'simon.audio.title'|trans }}</span>
                                </span>

                                <span class="simon-disclosure__state simon-disclosure__state--closed">
                                    {{ 'simon.panel.open'|trans }}
                                </span>
                                <span class="simon-disclosure__state simon-disclosure__state--open">
                                    {{ 'simon.panel.close'|trans }}
                                </span>
                            </summary>

                            <article class="simon-card simon-disclosure__content" data-simon-audio>
                                <div class="simon-audio__header">
                                    <p class="eyebrow">{{ 'simon.audio.eyebrow'|trans }}</p>

                                    <h3>{{ 'simon.audio.title'|trans }}</h3>
                                </div>

                                <div class="simon-audio__control">
                                    <label class="simon-audio__volume-label" for="simon-volume">
                                        {{ 'simon.audio.volume_label'|trans }}
                                    </label>

                                    <input
                                        id="simon-volume"
                                        type="range"
                                        min="0"
                                        max="100"
                                        step="1"
                                        value="75"
                                        data-simon-volume
                                    >

                                    <output class="simon-audio__value" data-simon-volume-value for="simon-volume">
                                        {{ 'simon.audio.volume_value'|trans({ volume: 75 }) }}
                                    </output>
                                </div>

                                <div class="simon-audio__control">
                                    <label class="simon-audio__volume-label" for="simon-note-duration">
                                        {{ 'simon.audio.note_duration_label'|trans }}
                                    </label>

                                    <input
                                        id="simon-note-duration"
                                        type="range"
                                        min="50"
                                        max="160"
                                        step="1"
                                        value="100"
                                        data-simon-note-duration
                                    >

                                    <output class="simon-audio__value" data-simon-note-duration-value for="simon-note-duration">
                                        {{ 'simon.audio.note_duration_value'|trans({ value: 100 }) }}
                                    </output>
                                </div>

                                <div class="simon-audio__control">
                                    <label class="simon-audio__volume-label" for="simon-reverb">
                                        {{ 'simon.audio.reverb_label'|trans }}
                                    </label>

                                    <input
                                        id="simon-reverb"
                                        type="range"
                                        min="0"
                                        max="100"
                                        step="1"
                                        value="12"
                                        data-simon-reverb
                                    >

                                    <output class="simon-audio__value" data-simon-reverb-value for="simon-reverb">
                                        {{ 'simon.audio.reverb_value'|trans({ value: 12 }) }}
                                    </output>
                                </div>

                                <div class="simon-audio__palette">
                                    <label class="simon-audio__palette-label" for="simon-audio-palette">
                                        {{ 'simon.audio.palette.label'|trans }}
                                    </label>

                                    <select
                                        id="simon-audio-palette"
                                        class="simon-audio__palette-select"
                                        data-simon-audio-palette
                                        aria-describedby="simon-audio-palette-description simon-audio-palette-feedback"
                                    >
                                        <option value="classic" data-description="{{ 'simon.audio.palettes.classic.description'|trans }}">
                                            {{ 'simon.audio.palettes.classic.label'|trans }}
                                        </option>
                                        <option value="arcade" data-description="{{ 'simon.audio.palettes.arcade.description'|trans }}">
                                            {{ 'simon.audio.palettes.arcade.label'|trans }}
                                        </option>
                                        <option value="crystal" data-description="{{ 'simon.audio.palettes.crystal.description'|trans }}">
                                            {{ 'simon.audio.palettes.crystal.label'|trans }}
                                        </option>
                                        <option value="synthwave" data-description="{{ 'simon.audio.palettes.synthwave.description'|trans }}">
                                            {{ 'simon.audio.palettes.synthwave.label'|trans }}
                                        </option>
                                        <option value="percussion" data-description="{{ 'simon.audio.palettes.percussion.description'|trans }}">
                                            {{ 'simon.audio.palettes.percussion.label'|trans }}
                                        </option>
                                    </select>

                                    <p id="simon-audio-palette-description" class="simon-audio__palette-description" data-simon-audio-palette-description>
                                        {{ 'simon.audio.palettes.classic.description'|trans }}
                                    </p>

                                    <button
                                        type="button"
                                        class="button button-secondary simon-audio__preview"
                                        data-simon-audio-palette-preview
                                        aria-describedby="simon-audio-palette-description simon-audio-palette-feedback"
                                    >
                                        {{ 'simon.audio.palette.preview'|trans }}
                                    </button>

                                    <p id="simon-audio-palette-feedback" class="simon-audio__palette-feedback" data-simon-audio-palette-feedback aria-live="polite">
                                        {{ 'simon.audio.palette.active'|trans({ label: 'simon.audio.palettes.classic.label'|trans }) }}
                                    </p>
                                </div>

                                <div class="simon-audio__note-set">
                                    <label class="simon-audio__palette-label" for="simon-audio-note-set">
                                        {{ 'simon.audio.note_set.label'|trans }}
                                    </label>

                                    <select
                                        id="simon-audio-note-set"
                                        class="simon-audio__palette-select"
                                        data-simon-audio-note-set
                                        aria-describedby="simon-audio-note-set-description simon-audio-note-set-feedback"
                                    >
                                        <option value="major" data-description="{{ 'simon.audio.note_sets.major.description'|trans }}">
                                            {{ 'simon.audio.note_sets.major.label'|trans }}
                                        </option>
                                        <option value="minor" data-description="{{ 'simon.audio.note_sets.minor.description'|trans }}">
                                            {{ 'simon.audio.note_sets.minor.label'|trans }}
                                        </option>
                                        <option value="pentatonic" data-description="{{ 'simon.audio.note_sets.pentatonic.description'|trans }}">
                                            {{ 'simon.audio.note_sets.pentatonic.label'|trans }}
                                        </option>
                                        <option value="dorian" data-description="{{ 'simon.audio.note_sets.dorian.description'|trans }}">
                                            {{ 'simon.audio.note_sets.dorian.label'|trans }}
                                        </option>
                                        <option value="blues" data-description="{{ 'simon.audio.note_sets.blues.description'|trans }}">
                                            {{ 'simon.audio.note_sets.blues.label'|trans }}
                                        </option>
                                    </select>

                                    <p id="simon-audio-note-set-description" class="simon-audio__palette-description" data-simon-audio-note-set-description>
                                        {{ 'simon.audio.note_sets.major.description'|trans }}
                                    </p>

                                    <p id="simon-audio-note-set-feedback" class="simon-audio__palette-feedback" data-simon-audio-note-set-feedback aria-live="polite">
                                        {{ 'simon.audio.note_set.active'|trans({ label: 'simon.audio.note_sets.major.label'|trans }) }}
                                    </p>
                                </div>

                                <p class="simon-audio__status" data-simon-audio-feedback aria-live="polite">
                                    {{ 'simon.audio.active'|trans({ volume: 75 }) }}
                                </p>
                            </article>
                        </details>

                        <details class="simon-disclosure simon-disclosure--instructions">
                            <summary class="simon-disclosure__summary">
                                <span class="simon-disclosure__text">
                                    <span class="eyebrow">{{ 'simon.instructions.eyebrow'|trans }}</span>
                                    <span class="simon-disclosure__title">{{ 'simon.instructions.title'|trans }}</span>
                                </span>

                                <span class="simon-disclosure__state simon-disclosure__state--closed">
                                    {{ 'simon.panel.open'|trans }}
                                </span>
                                <span class="simon-disclosure__state simon-disclosure__state--open">
                                    {{ 'simon.panel.close'|trans }}
                                </span>
                            </summary>

                            <article class="simon-card simon-disclosure__content">
                                <h3>{{ 'simon.instructions.title'|trans }}</h3>

                                <p id="simon-board-help">
                                    {{ 'simon.instructions.intro'|trans|highlight_keywords }}
                                </p>

                                <ul class="simon-shortcuts">
                                    <li>
                                        <span data-simon-keyboard-key="top-left">{{ 'simon.keyboard.default_keys.top_left'|trans }}</span>
                                        <span class="simon-shortcuts__zone">{{ 'simon.board.pads.top_left.label'|trans }}</span>
                                    </li>
                                    <li>
                                        <span data-simon-keyboard-key="top-right">{{ 'simon.keyboard.default_keys.top_right'|trans }}</span>
                                        <span class="simon-shortcuts__zone">{{ 'simon.board.pads.top_right.label'|trans }}</span>
                                    </li>
                                    <li>
                                        <span data-simon-keyboard-key="bottom-left">{{ 'simon.keyboard.default_keys.bottom_left'|trans }}</span>
                                        <span class="simon-shortcuts__zone">{{ 'simon.board.pads.bottom_left.label'|trans }}</span>
                                    </li>
                                    <li>
                                        <span data-simon-keyboard-key="bottom-right">{{ 'simon.keyboard.default_keys.bottom_right'|trans }}</span>
                                        <span class="simon-shortcuts__zone">{{ 'simon.board.pads.bottom_right.label'|trans }}</span>
                                    </li>
                                </ul>

                                <p id="simon-board-note" class="simon-note">
                                    {{ 'simon.instructions.note'|trans|highlight_keywords }}
                                </p>
                            </article>
                        </details>

                        <details class="simon-disclosure simon-disclosure--keyboard">
                            <summary class="simon-disclosure__summary">
                                <span class="simon-disclosure__text">
                                    <span class="eyebrow">{{ 'simon.keyboard.eyebrow'|trans }}</span>
                                    <span class="simon-disclosure__title">{{ 'simon.keyboard.title'|trans }}</span>
                                </span>

                                <span class="simon-disclosure__state simon-disclosure__state--closed">
                                    {{ 'simon.panel.open'|trans }}
                                </span>
                                <span class="simon-disclosure__state simon-disclosure__state--open">
                                    {{ 'simon.panel.close'|trans }}
                                </span>
                            </summary>

                            <article class="simon-card simon-keyboard simon-disclosure__content">
                                <p>{{ 'simon.keyboard.intro'|trans|highlight_keywords }}</p>

                                <p class="simon-keyboard__summary" data-simon-keyboard-summary>
                                    {{ 'simon.keyboard.summary_default'|trans }}
                                </p>

                                <ul class="simon-keyboard__map" aria-label="{{ 'simon.keyboard.summary_label'|trans }}">
                                    <li class="simon-keyboard__row" data-simon-keyboard-row="top-left">
                                        <span class="simon-keyboard__zone">{{ 'simon.keyboard.zones.top_left'|trans }}</span>
                                        <strong class="simon-keyboard__binding" data-simon-keyboard-key="top-left">A</strong>
                                        <button
                                            type="button"
                                            class="button button-secondary simon-keyboard__edit"
                                            data-simon-keyboard-edit="top-left"
                                        >
                                            {{ 'simon.keyboard.actions.edit'|trans }}
                                        </button>
                                    </li>

                                    <li class="simon-keyboard__row" data-simon-keyboard-row="top-right">
                                        <span class="simon-keyboard__zone">{{ 'simon.keyboard.zones.top_right'|trans }}</span>
                                        <strong class="simon-keyboard__binding" data-simon-keyboard-key="top-right">Z</strong>
                                        <button
                                            type="button"
                                            class="button button-secondary simon-keyboard__edit"
                                            data-simon-keyboard-edit="top-right"
                                        >
                                            {{ 'simon.keyboard.actions.edit'|trans }}
                                        </button>
                                    </li>

                                    <li class="simon-keyboard__row" data-simon-keyboard-row="bottom-left">
                                        <span class="simon-keyboard__zone">{{ 'simon.keyboard.zones.bottom_left'|trans }}</span>
                                        <strong class="simon-keyboard__binding" data-simon-keyboard-key="bottom-left">Q</strong>
                                        <button
                                            type="button"
                                            class="button button-secondary simon-keyboard__edit"
                                            data-simon-keyboard-edit="bottom-left"
                                        >
                                            {{ 'simon.keyboard.actions.edit'|trans }}
                                        </button>
                                    </li>

                                    <li class="simon-keyboard__row" data-simon-keyboard-row="bottom-right">
                                        <span class="simon-keyboard__zone">{{ 'simon.keyboard.zones.bottom_right'|trans }}</span>
                                        <strong class="simon-keyboard__binding" data-simon-keyboard-key="bottom-right">S</strong>
                                        <button
                                            type="button"
                                            class="button button-secondary simon-keyboard__edit"
                                            data-simon-keyboard-edit="bottom-right"
                                        >
                                            {{ 'simon.keyboard.actions.edit'|trans }}
                                        </button>
                                    </li>
                                </ul>

                                <p class="simon-keyboard__feedback" data-simon-keyboard-feedback aria-live="polite">
                                    {{ 'simon.keyboard.idle'|trans }}
                                </p>

                                <div class="simon-keyboard__actions">
                                    <button type="button" class="button button-secondary" data-simon-keyboard-reset>
                                        {{ 'simon.keyboard.actions.reset'|trans }}
                                    </button>
                                </div>
                            </article>
                        </details>

                        <details class="simon-disclosure simon-disclosure--rules">
                            <summary class="simon-disclosure__summary">
                                <span class="simon-disclosure__text">
                                    <span class="eyebrow">{{ 'simon.rules.eyebrow'|trans }}</span>
                                    <span class="simon-disclosure__title">{{ 'simon.rules.title'|trans }}</span>
                                </span>

                                <span class="simon-disclosure__state simon-disclosure__state--closed">
                                    {{ 'simon.panel.open'|trans }}
                                </span>
                                <span class="simon-disclosure__state simon-disclosure__state--open">
                                    {{ 'simon.panel.close'|trans }}
                                </span>
                            </summary>

                            <article class="simon-card simon-disclosure__content">
                                <ol class="simon-rules">
                                    <li>{{ 'simon.rules.step_1'|trans|highlight_keywords }}</li>
                                    <li>{{ 'simon.rules.step_2'|trans|highlight_keywords }}</li>
                                    <li>{{ 'simon.rules.step_3'|trans|highlight_keywords }}</li>
                                </ol>
