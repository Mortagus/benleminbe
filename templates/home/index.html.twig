{# Home - index.html.twig #}

{% trans_default_domain 'home' %}

{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.title'|trans }}{% endblock %}

{% block body %}
    <main class="landing-page">

        <section class="hero-section">
            <p class="eyebrow">{{ 'hero.eyebrow'|trans }}</p>

            <h1>{{ 'hero.name'|trans }}</h1>

            <h2>{{ 'hero.subtitle'|trans }}</h2>

            <p class="hero-intro">{{ 'hero.intro'|trans }}</p>

            <p class="hero-details">{{ 'hero.details_p1'|trans }}</p>
            <p class="hero-details">{{ 'hero.details_p2'|trans }}</p>

            <div class="buttons">
                <a href="mailto:benjamin@lemin.be" class="button">
                    {{ 'actions.contact'|trans }}
                </a>

                <a href="{{ asset('cv/benjamin_lemin_backend_developer_' ~ app.request.locale ~ '.pdf') }}?v={{ cvVersion }}"
                   class="button button-secondary"
                   target="_blank"
                   rel="noopener noreferrer"
                   data-track="cv">
                    {{ 'actions.download_cv'|trans }}
                </a>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'help.title'|trans }}</h2>

            <div class="cards-grid">
                <article class="card">
                    <h3>{{ 'help.card_1.title'|trans }}</h3>
                    <p>{{ 'help.card_1.text'|trans }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_2.title'|trans }}</h3>
                    <p>{{ 'help.card_2.text'|trans }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_3.title'|trans }}</h3>
                    <p>{{ 'help.card_3.text'|trans }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_4.title'|trans }}</h3>
                    <p>{{ 'help.card_4.text'|trans }}</p>
                </article>
            </div>
        </section>

        <section class="content-section content-section-highlight">
            <h2>{{ 'concrete.title'|trans }}</h2>

            <ul class="feature-list">
                <li>{{ 'concrete.item_1'|trans }}</li>
                <li>{{ 'concrete.item_2'|trans }}</li>
                <li>{{ 'concrete.item_3'|trans }}</li>
                <li>{{ 'concrete.item_4'|trans }}</li>
                <li>{{ 'concrete.item_5'|trans }}</li>
            </ul>
        </section>

        <section class="content-section">
            <h2>{{ 'stats.title'|trans }}</h2>

            <div class="stats-grid">
                <div class="stat-card">
                    <strong>{{ 'stats.experience.value'|trans }}</strong>
                    <span>{{ 'stats.experience.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'stats.stack.value'|trans }}</strong>
                    <span>{{ 'stats.stack.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'stats.production.value'|trans }}</strong>
                    <span>{{ 'stats.production.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'stats.teams.value'|trans }}</strong>
                    <span>{{ 'stats.teams.label'|trans }}</span>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'projects.title'|trans }}</h2>

            <div class="project-list">
                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'delcampe' }) }}" class="project-card-link">
                    <article class="project-card">
                        <p class="project-tag">{{ 'projects.delcampe.tag'|trans }}</p>
                        <h3>{{ 'projects.delcampe.title'|trans }}</h3>
                        <p>{{ 'projects.delcampe.text'|trans }}</p>
                    </article>
                </a>

                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'stanhome' }) }}" class="project-card-link">
                    <article class="project-card">
                        <p class="project-tag">{{ 'projects.stanhome.tag'|trans }}</p>
                        <h3>{{ 'projects.stanhome.title'|trans }}</h3>
                        <p>{{ 'projects.stanhome.text'|trans }}</p>
                    </article>
                </a>

                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'moveit' }) }}" class="project-card-link">
                    <article class="project-card">
                        <p class="project-tag">{{ 'projects.moveit.tag'|trans }}</p>
                        <h3>{{ 'projects.moveit.title'|trans }}</h3>
                        <p>{{ 'projects.moveit.text'|trans }}</p>
                    </article>
                </a>
            </div>

        </section>

        <section class="content-section content-section-highlight">
            <h2>{{ 'work_style.title'|trans }}</h2>

            <div class="split-content">
                <div>
                    <h3>{{ 'work_style.understand.title'|trans }}</h3>
                    <p>{{ 'work_style.understand.text'|trans }}</p>
                </div>

                <div>
                    <h3>{{ 'work_style.progressive.title'|trans }}</h3>
                    <p>{{ 'work_style.progressive.text'|trans }}</p>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'skills.title'|trans }}</h2>

            <div class="skills-groups">
                <div class="skills-group">
                    <h3>{{ 'skills.backend.title'|trans }}</h3>
                    <p>{{ 'skills.backend.text'|trans }}</p>
                </div>

                <div class="skills-group">
                    <h3>{{ 'skills.data.title'|trans }}</h3>
                    <p>{{ 'skills.data.text'|trans }}</p>
                </div>

                <div class="skills-group">
                    <h3>{{ 'skills.quality.title'|trans }}</h3>
                    <p>{{ 'skills.quality.text'|trans }}</p>
                </div>

                <div class="skills-group">
                    <h3>{{ 'skills.collaboration.title'|trans }}</h3>
                    <p>{{ 'skills.collaboration.text'|trans }}</p>
                </div>
            </div>
        </section>

        <section class="content-section">
            <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'coaching' }) }}"
                class="featured-card-link">
                <article class="card featured-card">
                    <div class="featured-card__content">
                        <h2>{{ 'coaching.title'|trans }}</h2>

                        <p>{{ 'coaching.paragraph_1'|trans }}</p>

                        <p>{{ 'coaching.paragraph_2'|trans }}</p>

                        <span class="featured-card__cta">
                    Voir le détail
                    <span class="featured-card__cta-icon" aria-hidden="true">→</span>
                </span>
                    </div>
                </article>
            </a>
        </section>

        <section class="content-section links-section">
            <h2>{{ 'links.title'|trans }}</h2>

            <div class="external-links external-links--featured">
                <a href="https://www.linkedin.com/in/benlem/" target="_blank" rel="noopener noreferrer" class="external-link-card">
                    <span class="external-link-card__icon external-link-card__icon--linkedin" aria-hidden="true"></span>
                    <span class="external-link-card__content">
                        <span class="external-link-card__label">LinkedIn</span>
                        <span class="external-link-card__description">{{ 'links.linkedin'|trans }}</span>
                    </span>
                </a>

                <a href="https://fr.malt.be/profile/benjaminlemin" target="_blank" rel="noopener noreferrer" class="external-link-card">
                    <span class="external-link-card__icon external-link-card__icon--malt" aria-hidden="true"></span>
                    <span class="external-link-card__content">
                        <span class="external-link-card__label">Malt</span>
                        <span class="external-link-card__description">{{ 'links.malt'|trans }}</span>
                    </span>
                </a>
            </div>

            <div class="external-links external-links--secondary">
                <a href="https://github.com/Mortagus" target="_blank" rel="noopener noreferrer" class="external-link-card external-link-card--compact">
                    <span class="external-link-card__icon external-link-card__icon--github" aria-hidden="true"></span>
                    <span class="external-link-card__label">GitHub</span>
                </a>

                <a href="https://www.superprof.be/coach-programmation-senior-php-dev-envie-accompagner-apprentissage-projets.html" target="_blank" rel="noopener noreferrer"
                   class="external-link-card external-link-card--compact">
                    <span class="external-link-card__icon external-link-card__icon--superprof" aria-hidden="true"></span>
                    <span class="external-link-card__label">Superprof</span>
                </a>

                <a href="https://www.apprentus.com/en-be/in/benjamin.lem" target="_blank" rel="noopener noreferrer" class="external-link-card external-link-card--compact">
                    <span class="external-link-card__icon external-link-card__icon--apprentus" aria-hidden="true"></span>
                    <span class="external-link-card__label">Apprentus</span>
                </a>
            </div>
        </section>

        <section class="contact-section">
            <h2>{{ 'contact.title'|trans }}</h2>

            <p>{{ 'contact.text'|trans }}</p>

            <div class="buttons">
                <a href="mailto:benjamin@lemin.be" class="button">
                    {{ 'actions.contact'|trans }}
                </a>

                <a href="{{ asset('cv/benjamin_lemin_backend_developer_' ~ app.request.locale ~ '.pdf') }}?v={{ cvVersion }}"
                   class="button button-secondary"
                   target="_blank"
                   rel="noopener noreferrer"
                   data-track="cv">
                    {{ 'actions.download_cv'|trans }}
                </a>
            </div>
        </section>

    </main>
{% endblock %}
