{# Home - index.html.twig #}

{% trans_default_domain 'home' %}

{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'meta.description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_home']) }}{% endblock %}

{% block body %}
    <main class="landing-page">

        <section class="hero-section">
            <p class="eyebrow">{{ 'hero.eyebrow'|trans }}</p>

            <h1>{{ 'hero.title'|trans }}</h1>

            <h2>{{ 'hero.name'|trans }} — {{ 'hero.subtitle'|trans }}</h2>

            <p class="hero-intro">{{ 'hero.intro'|trans|highlight_keywords }}</p>

            <p class="hero-details">{{ 'hero.details_p1'|trans|highlight_keywords }}</p>

            <div class="buttons">
                <a href="{{ path('app_contact', { _locale: app.request.locale}) }}" class="button">
                    {{ 'actions.contact'|trans }}
                </a>

                <a href="{{ asset('files/cv/Benjamin_Lemin_Senior_Backend_Developer_CV_2026_' ~ app.request.locale ~ '.pdf') }}?v={{ cvVersion }}"
                   class="button button-secondary"
                   target="_blank"
                   rel="noopener noreferrer"
                   data-track="cv">
                    {{ 'actions.download_cv'|trans }}
                </a>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'help.title'|trans }}</h2>

            <div class="cards-grid help-grid">
                <article class="card">
                    <h3>{{ 'help.card_1.title'|trans }}</h3>
                    <p>{{ 'help.card_1.text'|trans|highlight_keywords }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_2.title'|trans }}</h3>
                    <p>{{ 'help.card_2.text'|trans|highlight_keywords }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_3.title'|trans }}</h3>
                    <p>{{ 'help.card_3.text'|trans|highlight_keywords }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_4.title'|trans }}</h3>
                    <p>{{ 'help.card_4.text'|trans|highlight_keywords }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_5.title'|trans }}</h3>
                    <p>{{ 'help.card_5.text'|trans|highlight_keywords }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'help.card_6.title'|trans }}</h3>
                    <p>{{ 'help.card_6.text'|trans|highlight_keywords }}</p>
                </article>
            </div>
        </section>

        <section class="content-section content-section-highlight">
            <h2>{{ 'concrete.title'|trans }}</h2>

            <ul class="feature-list">
                <li>{{ 'concrete.item_1'|trans|highlight_keywords }}</li>
                <li>{{ 'concrete.item_2'|trans|highlight_keywords }}</li>
                <li>{{ 'concrete.item_3'|trans|highlight_keywords }}</li>
                <li>{{ 'concrete.item_4'|trans|highlight_keywords }}</li>
                <li>{{ 'concrete.item_5'|trans|highlight_keywords }}</li>
            </ul>
        </section>

        <section class="content-section">
            <h2>{{ 'projects.title'|trans }}</h2>

            <div class="project-list">
                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'delcampe' }) }}" class="project-card-link">
                    <article class="project-card">
                        <p class="project-tag">{{ 'projects.delcampe.tag'|trans }}</p>
                        <h3>{{ 'projects.delcampe.title'|trans }}</h3>
                        <p>{{ 'projects.delcampe.text'|trans|highlight_keywords }}</p>
                    </article>
                </a>

                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'stanhome' }) }}" class="project-card-link">
                    <article class="project-card">
                        <p class="project-tag">{{ 'projects.stanhome.tag'|trans }}</p>
                        <h3>{{ 'projects.stanhome.title'|trans }}</h3>
                        <p>{{ 'projects.stanhome.text'|trans|highlight_keywords }}</p>
                    </article>
                </a>

                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: 'moveit' }) }}" class="project-card-link">
                    <article class="project-card">
                        <p class="project-tag">{{ 'projects.moveit.tag'|trans }}</p>
                        <h3>{{ 'projects.moveit.title'|trans }}</h3>
                        <p>{{ 'projects.moveit.text'|trans|highlight_keywords }}</p>
                    </article>
                </a>
            </div>

        </section>

        <section class="content-section">
            <h2>{{ 'summary.title'|trans }}</h2>

            <div class="stats-grid">
                <div class="stat-card">
                    <strong>{{ 'summary.experience.value'|trans }}</strong>
                    <span>{{ 'summary.experience.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'summary.stack.value'|trans }}</strong>
                    <span>{{ 'summary.stack.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'summary.production.value'|trans }}</strong>
                    <span>{{ 'summary.production.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'summary.teams.value'|trans }}</strong>
                    <span>{{ 'summary.teams.label'|trans }}</span>
                </div>
            </div>
        </section>

        <section class="contact-section">
            <h2>{{ 'contact.title'|trans }}</h2>

            <p>{{ 'contact.text'|trans|highlight_keywords }}</p>

            <div class="buttons">

                <a href="{{ path('app_contact', { _locale: app.request.locale}) }}" class="button">
                    {{ 'actions.contact'|trans }}
                </a>

                <a href="{{ asset('files/cv/Benjamin_Lemin_Senior_Backend_Developer_CV_2026_' ~ app.request.locale ~ '.pdf') }}?v={{ cvVersion }}"
                   class="button button-secondary"
                   target="_blank"
                   rel="noopener noreferrer"
                   data-track="cv">
                    {{ 'actions.download_cv'|trans }}
                </a>
            </div>
        </section>

    </main>
{% endblock %}
