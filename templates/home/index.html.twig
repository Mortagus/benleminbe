{% extends 'base.html.twig' %}

{% block title %}{{ 'home.meta.title'|trans }}{% endblock %}

{% block body %}
    <main class="landing-page">

        <section class="hero-section">
            <p class="eyebrow">{{ 'home.hero.eyebrow'|trans }}</p>

            <h1>{{ 'home.hero.name'|trans }}</h1>

            <h2>{{ 'home.hero.subtitle'|trans }}</h2>

            <p class="hero-intro">{{ 'home.hero.intro'|trans }}</p>

            <p class="hero-details">{{ 'home.hero.details'|trans }}</p>

            <div class="buttons">
                <a href="mailto:benjamin@lemin.be" class="button">
                    {{ 'home.actions.contact'|trans }}
                </a>

                <a href="{{ asset('cv/benjamin_lemin_freelance_consultant_' ~ app.request.locale ~ '.pdf') }}"
                   class="button button-secondary"
                   target="_blank"
                   rel="noopener noreferrer">
                    {{ 'home.actions.download_cv'|trans }}
                </a>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'home.help.title'|trans }}</h2>

            <div class="cards-grid">
                <article class="card">
                    <h3>{{ 'home.help.card_1.title'|trans }}</h3>
                    <p>{{ 'home.help.card_1.text'|trans }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'home.help.card_2.title'|trans }}</h3>
                    <p>{{ 'home.help.card_2.text'|trans }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'home.help.card_3.title'|trans }}</h3>
                    <p>{{ 'home.help.card_3.text'|trans }}</p>
                </article>

                <article class="card">
                    <h3>{{ 'home.help.card_4.title'|trans }}</h3>
                    <p>{{ 'home.help.card_4.text'|trans }}</p>
                </article>
            </div>
        </section>

        <section class="content-section content-section-highlight">
            <h2>{{ 'home.concrete.title'|trans }}</h2>

            <ul class="feature-list">
                <li>{{ 'home.concrete.item_1'|trans }}</li>
                <li>{{ 'home.concrete.item_2'|trans }}</li>
                <li>{{ 'home.concrete.item_3'|trans }}</li>
                <li>{{ 'home.concrete.item_4'|trans }}</li>
                <li>{{ 'home.concrete.item_5'|trans }}</li>
            </ul>
        </section>

        <section class="content-section">
            <h2>{{ 'home.stats.title'|trans }}</h2>

            <div class="stats-grid">
                <div class="stat-card">
                    <strong>{{ 'home.stats.experience.value'|trans }}</strong>
                    <span>{{ 'home.stats.experience.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'home.stats.stack.value'|trans }}</strong>
                    <span>{{ 'home.stats.stack.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'home.stats.production.value'|trans }}</strong>
                    <span>{{ 'home.stats.production.label'|trans }}</span>
                </div>

                <div class="stat-card">
                    <strong>{{ 'home.stats.teams.value'|trans }}</strong>
                    <span>{{ 'home.stats.teams.label'|trans }}</span>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'home.projects.title'|trans }}</h2>

            <div class="project-list">
                <article class="project-card">
                    <p class="project-tag">{{ 'home.projects.delcampe.tag'|trans }}</p>
                    <h3>{{ 'home.projects.delcampe.title'|trans }}</h3>
                    <p>{{ 'home.projects.delcampe.text'|trans }}</p>
                </article>

                <article class="project-card">
                    <p class="project-tag">{{ 'home.projects.stanhome.tag'|trans }}</p>
                    <h3>{{ 'home.projects.stanhome.title'|trans }}</h3>
                    <p>{{ 'home.projects.stanhome.text'|trans }}</p>
                </article>

                <article class="project-card">
                    <p class="project-tag">{{ 'home.projects.moveit.tag'|trans }}</p>
                    <h3>{{ 'home.projects.moveit.title'|trans }}</h3>
                    <p>{{ 'home.projects.moveit.text'|trans }}</p>
                </article>
            </div>

            {# À activer quand la page /projets existera #}
            {# <a href="{{ path('app_projects') }}" class="text-link">Voir plus de projets</a> #}
        </section>

        <section class="content-section content-section-highlight">
            <h2>{{ 'home.work_style.title'|trans }}</h2>

            <div class="split-content">
                <div>
                    <h3>{{ 'home.work_style.understand.title'|trans }}</h3>
                    <p>{{ 'home.work_style.understand.text'|trans }}</p>
                </div>

                <div>
                    <h3>{{ 'home.work_style.progressive.title'|trans }}</h3>
                    <p>{{ 'home.work_style.progressive.text'|trans }}</p>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'home.skills.title'|trans }}</h2>

            <div class="skills-groups">
                <div class="skills-group">
                    <h3>{{ 'home.skills.backend.title'|trans }}</h3>
                    <p>{{ 'home.skills.backend.text'|trans }}</p>
                </div>

                <div class="skills-group">
                    <h3>{{ 'home.skills.data.title'|trans }}</h3>
                    <p>{{ 'home.skills.data.text'|trans }}</p>
                </div>

                <div class="skills-group">
                    <h3>{{ 'home.skills.quality.title'|trans }}</h3>
                    <p>{{ 'home.skills.quality.text'|trans }}</p>
                </div>

                <div class="skills-group">
                    <h3>{{ 'home.skills.collaboration.title'|trans }}</h3>
                    <p>{{ 'home.skills.collaboration.text'|trans }}</p>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'home.coaching.title'|trans }}</h2>

            <p>{{ 'home.coaching.paragraph_1'|trans }}</p>

            <p>{{ 'home.coaching.paragraph_2'|trans }}</p>

            {# À activer quand la page /coaching existera #}
            {# <a href="{{ path('app_coaching') }}" class="text-link">En savoir plus sur le coaching</a> #}
        </section>

        <section class="content-section links-section">
            <h2>{{ 'home.links.title'|trans }}</h2>

            <div class="external-links">
                <a href="https://www.linkedin.com/in/benlem/" target="_blank" rel="noopener noreferrer">
                    LinkedIn
                </a>

                <a href="https://fr.malt.be/profile/benjaminlemin" target="_blank" rel="noopener noreferrer">
                    Malt
                </a>

                <a href="https://github.com/Mortagus" target="_blank" rel="noopener noreferrer">
                    GitHub
                </a>

                <a href="https://www.superprof.be/coach-programmation-senior-php-dev-envie-accompagner-apprentissage-projets.html" target="_blank" rel="noopener noreferrer">
                    Superprof
                </a>

                <a href="https://www.apprentus.com/en-be/in/benjamin.lem" target="_blank" rel="noopener noreferrer">
                    Apprentus
                </a>
            </div>
        </section>

        <section class="contact-section">
            <h2>{{ 'home.contact.title'|trans }}</h2>

            <p>{{ 'home.contact.text'|trans }}</p>

            <div class="buttons">
                <a href="mailto:benjamin@lemin.be" class="button">
                    {{ 'home.actions.contact'|trans }}
                </a>

                <a href="{{ asset('cv/benjamin_lemin_freelance_consultant_' ~ app.request.locale ~ '.pdf') }}"
                   class="button button-secondary"
                   target="_blank"
                   rel="noopener noreferrer">
                    {{ 'home.actions.download_cv'|trans }}
                </a>
            </div>
        </section>

    </main>
{% endblock %}
