
<section class="card dnd-panel dnd-panel--monsters">
    <header class="dnd-panel__header">
        <div>
            <h2>Gestion des monstres</h2>
            <p>Choisis les monstres présents dans la rencontre.</p>
        </div>
    </header>

    <div class="dnd-toolbar">
        <div class="dnd-toolbar__field">
            <label for="monsterCount">Nombre de monstres</label>
            <input id="monsterCount" type="number" min="1" value="3">
        </div>

        <div class="dnd-toolbar__actions">
            <button id="createMonsters" type="button">Créer la liste</button>
            <button id="rollInitiative" type="button" disabled>Lancer l’initiative</button>
        </div>
    </div>

    <ul id="monsterList" class="monster-list"></ul>

    <template id="monsterItemTemplate">
        <li class="monster-item">
            <div class="monster-main">
                <select class="monster-select"></select>
                <span class="monster-type"></span>
            </div>

            <div class="monster-stats">
                <span class="monster-stat monster-armor-class"></span>

                <label class="monster-hp">
                    PV
                    <input type="number" min="0">
                    /
                    <span class="monster-hit-points-max"></span>
                </label>

                <span class="monster-stat monster-initiative-modifier"></span>
                <span class="monster-stat monster-initiative"></span>
            </div>
        </li>
    </template>
    <template id="monsterOptionTemplate">
        <option></option>
    </template>
</section>
