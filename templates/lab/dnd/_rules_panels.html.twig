<button
    id="openRulesPanel"
    type="button"
    class="dnd-secondary-button"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="rulesModal"
>
    Règles appliquées
</button>

<div
    id="rulesModal"
    class="rules-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="rulesModalTitle"
    hidden
>
    <div class="rules-modal__backdrop" data-rules-close></div>

    <section class="rules-modal__content" tabindex="-1">
        <header class="rules-modal__header">
            <div>
                <h2 id="rulesModalTitle">Règles appliquées</h2>
                <p>Active ou désactive les règles maison utilisées pour générer l'ordre du tour.</p>
            </div>

            <button type="button" class="dnd-secondary-button" data-rules-close>
                Fermer
            </button>
        </header>

        <ul class="rules-list">
            <li class="rules-list__item">
                <span class="rules-list__title">Ignorer les initiatives très basses</span>

                <div class="rules-list__actions">
                    <label class="rules-list__checkbox">
                        <input
                            type="checkbox"
                            data-rule-toggle="skip-low-initiative"
                            aria-label="Activer la règle : Ignorer les initiatives très basses"
                            checked
                        >
                    </label>

                    <span
                        class="rules-list__help"
                        title="Si cette règle est active, les acteurs avec une initiative de 1 ou moins ne sont pas ajoutés à l'ordre du tour."
                        aria-label="Si cette règle est active, les acteurs avec une initiative de 1 ou moins ne sont pas ajoutés à l'ordre du tour."
                        tabindex="0"
                    >
                        ?
                    </span>
                </div>
            </li>

            <li class="rules-list__item">
                <span class="rules-list__title">Accorder un tour supplémentaire sur initiative 20</span>

                <div class="rules-list__actions">
                    <label class="rules-list__checkbox">
                        <input
                            type="checkbox"
                            data-rule-toggle="extra-turn-on-twenty"
                            aria-label="Activer la règle : Accorder un tour supplémentaire sur initiative 20"
                            checked
                        >
                    </label>

                    <span
                        class="rules-list__help"
                        title="Si cette règle est active, un acteur avec une initiative finale de 20 reçoit deux tours dans l'ordre du tour."
                        aria-label="Si cette règle est active, un acteur avec une initiative finale de 20 reçoit deux tours dans l'ordre du tour."
                        tabindex="0"
                    >
                        ?
                    </span>
                </div>
            </li>
        </ul>
    </section>
</div>
