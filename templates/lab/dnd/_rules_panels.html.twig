<button
    id="openRulesPanel"
    type="button"
    class="dnd-secondary-button"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="rulesModal"
>
    Règles
</button>

<div
    id="rulesModal"
    class="rules-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="rulesModalTitle"
    hidden
>
    <div class="rules-modal__backdrop" data-rules-close></div>

    <section class="rules-modal__content" tabindex="-1">
        <header class="rules-modal__header">
            <div>
                <h2 id="rulesModalTitle">Règles</h2>
                <p>Règles maison appliquées à l’ordre du tour.</p>
            </div>

            <button type="button" class="dnd-secondary-button" data-rules-close>
                Fermer
            </button>
        </header>

        <ul class="rules-list">
            <li class="rules-list__item">
                <span class="rules-list__title">Ignorer initiative ≤ 1</span>

                <div class="rules-list__actions">
                    <label class="rules-list__checkbox">
                        <input
                            type="checkbox"
                            data-rule-toggle="skip-low-initiative"
                            aria-label="Activer la règle : Ignorer initiative 1 ou moins"
                            checked
                        >
                    </label>

                    <span
                        class="rules-list__help"
                        title="Les acteurs avec une initiative de 1 ou moins ne sont pas ajoutés à l’ordre du tour."
                        aria-label="Les acteurs avec une initiative de 1 ou moins ne sont pas ajoutés à l’ordre du tour."
                        tabindex="0"
                    >
                        ?
                    </span>
                </div>
            </li>

            <li class="rules-list__item">
                <span class="rules-list__title">Tour bonus sur initiative 20</span>

                <div class="rules-list__actions">
                    <label class="rules-list__checkbox">
                        <input
                            type="checkbox"
                            data-rule-toggle="extra-turn-on-twenty"
                            aria-label="Activer la règle : Tour bonus sur initiative 20"
                            checked
                        >
                    </label>

                    <span
                        class="rules-list__help"
                        title="Un acteur avec une initiative finale de 20 reçoit deux tours."
                        aria-label="Un acteur avec une initiative finale de 20 reçoit deux tours."
                        tabindex="0"
                    >
                        ?
                    </span>
                </div>
            </li>

            <li class="rules-list__item">
                <span class="rules-list__title">Égalités par DEX</span>

                <div class="rules-list__actions">
                    <label class="rules-list__checkbox">
                        <input
                            type="checkbox"
                            data-rule-toggle="break-initiative-ties-with-dexterity"
                            aria-label="Activer la règle : Égalités par DEX"
                        >
                    </label>

                    <span
                        class="rules-list__help"
                        title="En cas d’égalité, le meilleur mod. DEX passe devant. Les joueurs valent 0 pour l’instant."
                        aria-label="En cas d’égalité, le meilleur modificateur de DEX passe devant. Les joueurs valent 0 pour l’instant."
                        tabindex="0"
                    >
                        ?
                    </span>
                </div>
            </li>
        </ul>
    </section>
</div>
