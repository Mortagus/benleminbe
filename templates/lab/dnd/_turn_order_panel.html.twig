<section class="card dnd-panel dnd-panel--turn-order">
    <header class="dnd-panel__header dnd-panel__header--with-action">
        <div>
            <h2>Ordre du tour</h2>
            <p>Les acteurs prêts à jouer apparaîtront ici.</p>
        </div>

        <div class="dnd-panel__actions">
            {% include 'lab/dnd/_rules_panels.html.twig' %}

            <button id="generateTurnOrder" type="button" class="dnd-secondary-button">
                Générer l’ordre
            </button>

            <button
                id="toggleTurnOrderKeyboardHelp"
                type="button"
                class="turn-order-help-button dnd-icon-button"
                aria-label="Afficher l’aide clavier"
                aria-controls="turnOrderKeyboardHelp"
                aria-expanded="false"
                title="Aide clavier"
            >
                ?
            </button>
        </div>
    </header>

    <div id="turnOrderValidationSummary" class="dnd-validation-summary" role="alert" hidden></div>

    <div id="turnOrderKeyboardHelp" class="turn-order-keyboard-help" hidden>
        <p>Contrôles clavier</p>
        <ul>
            <li><kbd>Tab</kbd> parcourt les tuiles.</li>
            <li><kbd>Entrée</kbd> ou <kbd>Espace</kbd> bascule joué.</li>
            <li><kbd>←</kbd> et <kbd>→</kbd> déplacent l’acteur.</li>
        </ul>
    </div>

    <div class="turn-order-combat-controls">
        <div class="turn-order-combat-status">
            <p id="combatRoundStatus" class="turn-order-combat-status__round">Round 1</p>
            <p
                id="combatTurnStatus"
                class="turn-order-combat-status__turn"
                aria-live="polite"
                aria-atomic="true"
            >
                Aucun ordre du tour généré.
            </p>
        </div>

        <div class="turn-order-combat-actions">
            <button
                id="combatNextTurn"
                type="button"
                class="dnd-secondary-button turn-order-combat-button turn-order-combat-button--primary"
                disabled
            >
                Acteur suivant
            </button>

            <button
                id="combatStartNewRound"
                type="button"
                class="dnd-secondary-button turn-order-combat-button"
                disabled
            >
                Nouveau round
            </button>

            <button
                id="combatResetTurnProgress"
                type="button"
                class="dnd-secondary-button turn-order-combat-button"
                disabled
            >
                Réinitialiser les tours de ce round
            </button>
        </div>
    </div>

    <div id="turnOrderPlaceholder" class="dnd-placeholder">
        <p>Aucun ordre généré.</p>
    </div>

    <ol id="turnOrderList" class="turn-order-list" hidden></ol>
    <div id="turnOrderLiveRegion" class="turn-order-live-region" aria-live="polite" aria-atomic="true"></div>

    <div
        id="encounterRestoreModal"
        class="dnd-persistence-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="encounterRestoreModalTitle"
        aria-describedby="encounterRestoreSummary"
        hidden
    >
        <div class="dnd-persistence-modal__backdrop" data-persistence-close></div>

        <section class="dnd-persistence-modal__content" tabindex="-1">
            <header class="dnd-persistence-modal__header">
                <div>
                    <h2 id="encounterRestoreModalTitle">Restaurer la sauvegarde locale ?</h2>
                    <p>Une sauvegarde compatible est disponible dans ce navigateur.</p>
                </div>

                <button
                    id="resetEncounterSnapshot"
                    type="button"
                    class="dnd-secondary-button"
                >
                    Réinitialiser
                </button>
            </header>

            <div class="dnd-persistence-modal__body">
                <p id="encounterRestoreSummary" class="dnd-persistence-modal__summary"></p>
                <p class="dnd-persistence-modal__hint">
                    Charger la sauvegarde remplacera l’état actuel du tracker.
                </p>
            </div>

            <footer class="dnd-persistence-modal__footer">
                <button
                    id="encounterRestoreLoad"
                    type="button"
                    class="dnd-secondary-button"
                >
                    Charger la sauvegarde
                </button>
            </footer>
        </section>
    </div>
    <div
        id="encounterPersistenceErrorModal"
        class="dnd-persistence-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="encounterPersistenceErrorModalTitle"
        aria-describedby="encounterPersistenceErrorMessage"
        hidden
    >
        <div class="dnd-persistence-modal__backdrop" data-persistence-error-close></div>

        <section class="dnd-persistence-modal__content" tabindex="-1">
            <header class="dnd-persistence-modal__header">
                <div>
                    <h2 id="encounterPersistenceErrorModalTitle">Sauvegarde locale indisponible</h2>
                    <p>Le tracker a rencontré un problème avec localStorage ou le snapshot.</p>
                </div>

                <button type="button" class="dnd-secondary-button" data-persistence-error-close>
                    Fermer
                </button>
            </header>

            <div class="dnd-persistence-modal__body">
                <p class="dnd-persistence-modal__hint">
                    Le message ci-dessous est en lecture seule et peut être copié tel quel.
                </p>

                <textarea
                    id="encounterPersistenceErrorMessage"
                    class="dnd-persistence-modal__message"
                    readonly
                    rows="12"
                ></textarea>
            </div>
        </section>
    </div>

    <template id="turnOrderItemTemplate">
        <li class="turn-order-item">
            <div class="turn-order-item__controls" aria-hidden="false">
                <button
                    type="button"
                    class="turn-order-item__move-button turn-order-item__move-button--compact dnd-icon-button"
                    data-turn-move="previous"
                >
                    <svg class="dnd-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>

                <button
                    type="button"
                    class="turn-order-item__move-button turn-order-item__move-button--compact dnd-icon-button"
                    data-turn-move="next"
                >
                    <svg class="dnd-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>
            </div>

            <div class="turn-order-item__badges">
                <span class="turn-order-item__legendary-badge" hidden></span>
            </div>

            <div class="turn-order-item__image-placeholder"></div>

            <div class="turn-order-item__name"></div>

            <div class="turn-order-item__stats">
                <span class="turn-order-item__initiative"></span>
                <span class="turn-order-item__armor-class"></span>
                <span class="turn-order-item__hit-points"></span>
            </div>

            <div class="turn-order-item__badge" hidden>À jouer</div>
        </li>
    </template>
</section>
