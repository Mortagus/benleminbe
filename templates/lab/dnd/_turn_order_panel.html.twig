<section class="card dnd-panel dnd-panel--turn-order">
    <header class="dnd-panel__header dnd-panel__header--with-action">
        <div>
            <h2>Ordre du tour</h2>
            <p>La liste d’initiative complète apparaîtra ici.</p>
        </div>

        <div class="dnd-panel__actions">
            <button id="generateTurnOrder" type="button" class="dnd-secondary-button">
                Générer le tour de table
            </button>

            {% include 'lab/dnd/_rules_panels.html.twig' %}
        </div>
    </header>

    <div id="turnOrderValidationSummary" class="dnd-validation-summary" role="alert" hidden></div>

    <div id="turnOrderPlaceholder" class="dnd-placeholder">
        <p>Aucun tour de combat généré pour le moment.</p>
    </div>

    <ol id="turnOrderList" class="turn-order-list" hidden></ol>

    <template id="turnOrderItemTemplate">
        <li class="turn-order-item">
            <div class="turn-order-item__image-placeholder"></div>

            <div class="turn-order-item__name"></div>

            <div class="turn-order-item__stats">
                <span class="turn-order-item__initiative"></span>
                <span class="turn-order-item__armor-class"></span>
                <span class="turn-order-item__hit-points"></span>
            </div>

            <div class="turn-order-item__badge" hidden>À jouer</div>
        </li>
    </template>
</section>
