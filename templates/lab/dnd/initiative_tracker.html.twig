{# Dnd Initiative - initiative_tracker.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}D&D Initiative Tracker{% endblock %}
{% block meta_description %}D&D Initiative Tracker Tool for Awesome GMs{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_lab', 'dnd_initiative']) }}{% endblock %}

{% block body %}
    <main class="lab-initiative-page dnd-initiative-page">
        <section class="content-section">
            <header class="dnd-page-header dnd-page-header--with-action">
                <div class="dnd-page-header__content">
                    <h1>D&D Initiative Tracker</h1>

                    <p>
                        Préparer une rencontre, lancer l’initiative et suivre l’ordre du tour.
                    </p>
                </div>

                <div class="dnd-page-header__actions">
                    <p id="resetEncounterWarning" class="dnd-page-header__warning">
                        Action globale : réinitialise monstres, joueurs, ordre du tour, round et état joué.
                    </p>

                    <button
                        id="resetEncounter"
                        type="button"
                        class="dnd-secondary-button dnd-secondary-button--danger"
                        aria-describedby="resetEncounterWarning"
                        title="Action globale sur l’ensemble de l’outil"
                        disabled
                    >
                        Réinitialiser la rencontre
                    </button>
                </div>
            </header>

            <div class="dnd-layout">

                {% include 'lab/dnd/_monsters_panel.html.twig' %}
                {% include 'lab/dnd/_players_panel.html.twig' %}
                {% include 'lab/dnd/_turn_order_panel.html.twig' %}

            </div>

            <div class="dnd-persistence-controls dnd-persistence-controls--footer">
                <p
                    id="encounterPersistenceStatus"
                    class="dnd-persistence-status"
                    aria-live="polite"
                >
                    Aucune sauvegarde locale.
                </p>

                <button
                    id="restoreEncounterSnapshot"
                    type="button"
                    class="dnd-secondary-button dnd-secondary-button--compact"
                    aria-haspopup="dialog"
                    aria-controls="encounterRestoreModal"
                    aria-expanded="false"
                    aria-label="Restaurer la dernière sauvegarde"
                    title="Restaurer la dernière sauvegarde"
                    disabled
                >
                    Restaurer
                </button>
            </div>
        </section>
    </main>
{% endblock %}
