{# templates/pages/about.html.twig #}

{% extends 'base.html.twig' %}

{% trans_default_domain 'about' %}

{% block title %}{{ 'about.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'about.meta.description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_about']) }}{% endblock %}

{% block body %}
    <main class="about-page">
        <header class="about-hero">
            <p class="eyebrow">{{ 'about.hero.eyebrow'|trans }}</p>

            <h1>{{ 'about.hero.title'|trans }}</h1>

            <p class="about-hero__intro">
                {{ 'about.hero.intro'|trans|highlight_keywords }}
            </p>
        </header>

        <section class="content-section" aria-labelledby="about-work">
            <div class="card">
                <h2 id="about-work">{{ 'about.sections.work.title'|trans }}</h2>

                <p>{{ 'about.sections.work.paragraphs.1'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.work.paragraphs.2'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.work.paragraphs.3'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.work.paragraphs.4'|trans|highlight_keywords }}</p>

            </div>
        </section>

        <section class="content-section" aria-labelledby="about-now">
            <div class="card">
                <h2 id="about-now">{{ 'about.sections.now.title'|trans }}</h2>

                <p>{{ 'about.sections.now.paragraphs.1'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.now.paragraphs.2'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.now.paragraphs.3'|trans|highlight_keywords }}</p>

            </div>
        </section>

        <section class="content-section" aria-labelledby="about-coaching">
            <div class="card">
                <h2 id="about-coaching">{{ 'about.sections.coaching.title'|trans }}</h2>

                <p>{{ 'about.sections.coaching.paragraphs.1'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.coaching.paragraphs.2'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.coaching.paragraphs.3'|trans|highlight_keywords }}</p>

            </div>
        </section>

        <section class="content-section" aria-labelledby="about-why-it">
            <div class="card">
                <h2 id="about-why-it">{{ 'about.sections.why_it.title'|trans }}</h2>

                <p>{{ 'about.sections.why_it.paragraphs.1'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.why_it.paragraphs.2'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.why_it.paragraphs.3'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.why_it.paragraphs.4'|trans|highlight_keywords }}</p>

            </div>
        </section>

        <section class="content-section" aria-labelledby="about-interests">
            <div class="card">
                <h2 id="about-interests">{{ 'about.sections.interests.title'|trans }}</h2>

                <p>{{ 'about.sections.interests.paragraphs.1'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.interests.paragraphs.2'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.interests.paragraphs.3'|trans|highlight_keywords }}</p>

            </div>
        </section>

        <section class="content-section" aria-labelledby="about-website">
            <div class="card">
                <h2 id="about-website">{{ 'about.sections.website.title'|trans }}</h2>

                <p>{{ 'about.sections.website.paragraphs.1'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.website.paragraphs.2'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.website.paragraphs.3'|trans|highlight_keywords }}</p>
                <p>{{ 'about.sections.website.paragraphs.4'|trans|highlight_keywords }}</p>

            </div>
        </section>

        <section class="content-section" aria-labelledby="about-links">
            <div class="card">
                <h2 id="about-links">{{ 'about.sections.links.title'|trans }}</h2>

                <ul class="feature-list">
                    <li>
                        <a href="{{ path('app_projects_index', { _locale: app.request.locale }) }}">
                            {{ 'about.links.projects'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_experiences_index', { _locale: app.request.locale }) }}">
                            {{ 'about.links.experiences'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_contact', { _locale: app.request.locale }) }}">
                            {{ 'about.links.contact'|trans }}
                        </a>
                    </li>
                </ul>
            </div>
        </section>
    </main>
{% endblock %}
