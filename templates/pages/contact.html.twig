{# templates/pages/contact.html.twig #}

{% extends 'base.html.twig' %}

{% trans_default_domain 'contact' %}

{% block title %}{{ 'contact.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'contact.meta.description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_contact']) }}{% endblock %}

{% block body %}
    <main class="contact-page">
        <header class="contact-hero">
            <p class="contact-hero__eyebrow">{{ 'contact.hero.eyebrow'|trans }}</p>

            <h1>{{ 'contact.hero.title'|trans }}</h1>

            <p class="contact-hero__intro">
                {{ 'contact.hero.intro'|trans|highlight_keywords }}
            </p>

            <div class="contact-hero__actions" aria-label="{{ 'contact.hero.actions.label'|trans }}">
                <a class="button" href="mailto:benjamin@lemin.be">
                    {{ 'contact.hero.actions.email'|trans }}
                </a>

                <a class="button button-secondary" href="https://www.linkedin.com/in/benlem/" target="_blank" rel="noopener noreferrer">
                    {{ 'contact.hero.actions.linkedin'|trans }}
                </a>
            </div>

            <p class="contact-hero__note">{{ 'contact.hero.note'|trans|highlight_keywords }}</p>
        </header>

        <section class="content-section" aria-labelledby="contact-methods-title">
            <div class="card contact-panel">
                <div class="contact-panel__intro">
                    <p class="eyebrow">{{ 'contact.methods.eyebrow'|trans }}</p>

                    <h2 id="contact-methods-title">{{ 'contact.methods.title'|trans }}</h2>

                    <p>{{ 'contact.methods.intro'|trans|highlight_keywords }}</p>
                </div>

                <div class="contact-methods__grid">
                    <a class="contact-card contact-card--primary" href="mailto:benjamin@lemin.be">
                        <span class="contact-card__icon">@</span>
                        <span class="contact-card__content">
                            <strong>{{ 'contact.methods.email.name'|trans }}</strong>
                            <span>{{ 'contact.methods.email.description'|trans|highlight_keywords }}</span>
                        </span>
                        <span class="contact-card__action">{{ 'contact.methods.email.action'|trans }}</span>
                    </a>

                    <a class="contact-card" href="https://www.linkedin.com/in/benlem/" target="_blank" rel="noopener noreferrer">
                        <span class="contact-card__icon">in</span>
                        <span class="contact-card__content">
                            <strong>{{ 'contact.methods.linkedin.name'|trans }}</strong>
                            <span>{{ 'contact.methods.linkedin.description'|trans|highlight_keywords }}</span>
                        </span>
                        <span class="contact-card__action">{{ 'contact.methods.linkedin.action'|trans }}</span>
                    </a>

                    <a class="contact-card" href="https://fr.malt.be/profile/benjaminlemin" target="_blank" rel="noopener noreferrer">
                        <span class="contact-card__icon">M</span>
                        <span class="contact-card__content">
                            <strong>{{ 'contact.methods.malt.name'|trans }}</strong>
                            <span>{{ 'contact.methods.malt.description'|trans|highlight_keywords }}</span>
                        </span>
                        <span class="contact-card__action">{{ 'contact.methods.malt.action'|trans }}</span>
                    </a>

                    <a class="contact-card" href="https://wa.me/32495851919" target="_blank" rel="noopener noreferrer">
                        <span class="contact-card__icon">☎</span>
                        <span class="contact-card__content">
                            <strong>{{ 'contact.methods.whatsapp.name'|trans }}</strong>
                            <span>{{ 'contact.methods.whatsapp.description'|trans|highlight_keywords }}</span>
                        </span>
                        <span class="contact-card__action">{{ 'contact.methods.whatsapp.action'|trans }}</span>
                    </a>
                </div>
            </div>
        </section>

        <section class="contact-details-grid">
            <div class="card contact-detail-card">
                <h2>{{ 'contact.details.request.title'|trans }}</h2>

                <p>{{ 'contact.details.request.intro'|trans|highlight_keywords }}</p>

                <ul class="feature-list">
                    <li>{{ 'contact.details.request.item_1'|trans|highlight_keywords }}</li>
                    <li>{{ 'contact.details.request.item_2'|trans|highlight_keywords }}</li>
                    <li>{{ 'contact.details.request.item_3'|trans|highlight_keywords }}</li>
                    <li>{{ 'contact.details.request.item_4'|trans|highlight_keywords }}</li>
                </ul>
            </div>

            <div class="card contact-detail-card contact-detail-card--accent">
                <h2>{{ 'contact.details.availability.title'|trans }}</h2>

                <p>{{ 'contact.details.availability.paragraph_1'|trans|highlight_keywords }}</p>

                <p>{{ 'contact.details.availability.paragraph_2'|trans|highlight_keywords }}</p>
            </div>
        </section>
    </main>
{% endblock %}
