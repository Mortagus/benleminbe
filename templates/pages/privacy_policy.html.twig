{# templates/pages/privacy_policy.html.twig #}

{% extends 'base.html.twig' %}

{% trans_default_domain 'legal' %}

{% block title %}{{ 'privacy_policy.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'privacy_policy.meta.description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_legal']) }}{% endblock %}

{% block body %}
    <main class="legal-page">
        <header class="legal-hero">
            <p class="eyebrow">{{ 'privacy_policy.hero.eyebrow'|trans }}</p>

            <h1>{{ 'privacy_policy.hero.title'|trans }}</h1>
        </header>

        <section class="content-section" aria-labelledby="privacy-controller">
            <div class="card">
                <h2 id="privacy-controller">{{ 'privacy_policy.sections.controller.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.controller.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.controller.paragraphs.2'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-data-collected">
            <div class="card">
                <h2 id="privacy-data-collected">{{ 'privacy_policy.sections.data_collected.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.data_collected.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.data_collected.paragraphs.2'|trans }}</p>
                <p>{{ 'privacy_policy.sections.data_collected.paragraphs.3'|trans }}</p>
                <p>{{ 'privacy_policy.sections.data_collected.paragraphs.4'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-purposes">
            <div class="card">
                <h2 id="privacy-purposes">{{ 'privacy_policy.sections.purposes.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.purposes.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.purposes.paragraphs.2'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-legal-basis">
            <div class="card">
                <h2 id="privacy-legal-basis">{{ 'privacy_policy.sections.legal_basis.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.legal_basis.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.legal_basis.paragraphs.2'|trans }}</p>
                <p>{{ 'privacy_policy.sections.legal_basis.paragraphs.3'|trans }}</p>
                <p>{{ 'privacy_policy.sections.legal_basis.paragraphs.4'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-retention">
            <div class="card">
                <h2 id="privacy-retention">{{ 'privacy_policy.sections.retention.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.retention.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.retention.paragraphs.2'|trans }}</p>
                <p>{{ 'privacy_policy.sections.retention.paragraphs.3'|trans }}</p>
                <p>{{ 'privacy_policy.sections.retention.paragraphs.4'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-recipients">
            <div class="card">
                <h2 id="privacy-recipients">{{ 'privacy_policy.sections.recipients.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.recipients.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.recipients.paragraphs.2'|trans }}</p>
                <p>{{ 'privacy_policy.sections.recipients.paragraphs.3'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-external-links">
            <div class="card">
                <h2 id="privacy-external-links">{{ 'privacy_policy.sections.external_links.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.external_links.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.external_links.paragraphs.2'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-cookies">
            <div class="card">
                <h2 id="privacy-cookies">{{ 'privacy_policy.sections.cookies.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.cookies.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.cookies.paragraphs.2'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-security">
            <div class="card">
                <h2 id="privacy-security">{{ 'privacy_policy.sections.security.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.security.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.security.paragraphs.2'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-rights">
            <div class="card">
                <h2 id="privacy-rights">{{ 'privacy_policy.sections.rights.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.rights.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.rights.paragraphs.2'|trans }}</p>
                <p>{{ 'privacy_policy.sections.rights.paragraphs.3'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-complaint">
            <div class="card">
                <h2 id="privacy-complaint">{{ 'privacy_policy.sections.complaint.title'|trans }}</h2>
                <p>{{ 'privacy_policy.sections.complaint.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.complaint.paragraphs.2'|trans }}</p>
            </div>
        </section>

        <section class="content-section" aria-labelledby="privacy-updates">
            <div class="card">
                <h2 id="privacy-updates">{{ 'privacy_policy.sections.updates.title'|trans }}</h2>

                <p>
                    <strong>{{ 'privacy_policy.sections.updates.last_updated.label'|trans }} :</strong>
                    {{ 'privacy_policy.sections.updates.last_updated.value'|trans }}
                </p>

                <p>{{ 'privacy_policy.sections.updates.paragraphs.1'|trans }}</p>
                <p>{{ 'privacy_policy.sections.updates.paragraphs.2'|trans }}</p>
                <p>{{ 'privacy_policy.sections.updates.paragraphs.3'|trans }}</p>
            </div>
        </section>
    </main>
{% endblock %}
