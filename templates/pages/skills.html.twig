{# templates/pages/skills.html.twig #}

{% extends 'base.html.twig' %}

{% trans_default_domain 'skills' %}

{% block title %}{{ 'meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'meta.description'|trans }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_skills']) }}{% endblock %}

{% block body %}
    <main class="skills-page">
        <header class="skills-hero">
            <p class="eyebrow">{{ 'hero.eyebrow'|trans }}</p>

            <h1>{{ 'hero.title'|trans }}</h1>

            <p class="skills-hero__intro">
                {{ 'hero.intro'|trans|highlight_keywords }}
            </p>

            <div class="skills-hero__facts" aria-label="{{ 'hero.facts.label'|trans }}">
                <article class="skills-hero__fact">
                    <strong>{{ 'hero.facts.experience.value'|trans }}</strong>
                    <span>{{ 'hero.facts.experience.label'|trans }}</span>
                </article>

                <article class="skills-hero__fact">
                    <strong>{{ 'hero.facts.stack.value'|trans }}</strong>
                    <span>{{ 'hero.facts.stack.label'|trans }}</span>
                </article>

                <article class="skills-hero__fact">
                    <strong>{{ 'hero.facts.evolution.value'|trans }}</strong>
                    <span>{{ 'hero.facts.evolution.label'|trans }}</span>
                </article>
            </div>
        </header>

        <section class="content-section" aria-labelledby="skills-core-title">
            <div class="card card--accent skills-panel">
                <div class="skills-panel__intro">
                    <p class="eyebrow">{{ 'sections.core.eyebrow'|trans }}</p>

                    <h2 id="skills-core-title">{{ 'sections.core.title'|trans }}</h2>

                    <p>{{ 'sections.core.intro'|trans|highlight_keywords }}</p>
                </div>

                <div class="skills-highlight-grid skills-highlight-grid--tight">
                    <article>
                        <h3>{{ 'core.backend_stack.title'|trans }}</h3>
                        <p>{{ 'core.backend_stack.text'|trans|highlight_keywords }}</p>
                    </article>

                    <article>
                        <h3>{{ 'core.business_apps.title'|trans }}</h3>
                        <p>{{ 'core.business_apps.text'|trans|highlight_keywords }}</p>
                    </article>

                    <article>
                        <h3>{{ 'core.apis.title'|trans }}</h3>
                        <p>{{ 'core.apis.text'|trans|highlight_keywords }}</p>
                    </article>

                    <article>
                        <h3>{{ 'core.maintenance.title'|trans }}</h3>
                        <p>{{ 'core.maintenance.text'|trans|highlight_keywords }}</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="content-section" aria-labelledby="skills-regular-title">
            <div class="card skills-panel">
                <div class="skills-panel__intro">
                    <p class="eyebrow">{{ 'sections.regular.eyebrow'|trans }}</p>

                    <h2 id="skills-regular-title">{{ 'sections.regular.title'|trans }}</h2>

                    <p class="skills-panel__lead">{{ 'sections.regular.intro'|trans|highlight_keywords }}</p>
                </div>

                <div class="skills-category-list">
                    <article class="skills-category">
                        <h3>{{ 'regular.data.title'|trans }}</h3>
                        <ul class="tag-list">
                            <li>{{ 'regular.data.items.1'|trans }}</li>
                            <li>{{ 'regular.data.items.2'|trans }}</li>
                            <li>{{ 'regular.data.items.3'|trans }}</li>
                            <li>{{ 'regular.data.items.4'|trans }}</li>
                        </ul>
                    </article>

                    <article class="skills-category">
                        <h3>{{ 'regular.delivery.title'|trans }}</h3>
                        <ul class="tag-list">
                            <li>{{ 'regular.delivery.items.1'|trans }}</li>
                            <li>{{ 'regular.delivery.items.2'|trans }}</li>
                            <li>{{ 'regular.delivery.items.3'|trans }}</li>
                            <li>{{ 'regular.delivery.items.4'|trans }}</li>
                        </ul>
                    </article>

                    <article class="skills-category">
                        <h3>{{ 'regular.interface.title'|trans }}</h3>
                        <ul class="tag-list">
                            <li>{{ 'regular.interface.items.1'|trans }}</li>
                            <li>{{ 'regular.interface.items.2'|trans }}</li>
                            <li>{{ 'regular.interface.items.3'|trans }}</li>
                            <li>{{ 'regular.interface.items.4'|trans }}</li>
                            <li>{{ 'regular.interface.items.5'|trans }}</li>
                        </ul>
                    </article>

                    <article class="skills-category">
                        <h3>{{ 'regular.quality.title'|trans }}</h3>
                        <ul class="tag-list">
                            <li>{{ 'regular.quality.items.1'|trans }}</li>
                            <li>{{ 'regular.quality.items.2'|trans }}</li>
                            <li>{{ 'regular.quality.items.3'|trans }}</li>
                            <li>{{ 'regular.quality.items.4'|trans }}</li>
                            <li>{{ 'regular.quality.items.5'|trans }}</li>
                        </ul>
                    </article>
                </div>
            </div>
        </section>

        <section class="content-section" aria-labelledby="skills-complementary-title">
            <div class="card skills-panel">
                <div class="skills-panel__intro">
                    <p class="eyebrow">{{ 'sections.complementary.eyebrow'|trans }}</p>

                    <h2 id="skills-complementary-title">{{ 'sections.complementary.title'|trans }}</h2>

                    <p class="skills-panel__lead">{{ 'sections.complementary.intro'|trans|highlight_keywords }}</p>
                </div>

                <div class="skills-two-columns">
                    <div>
                        <h3>{{ 'complementary.tools.title'|trans }}</h3>
                        <ul class="tag-list">
                            <li>{{ 'complementary.tools.items.1'|trans }}</li>
                            <li>{{ 'complementary.tools.items.2'|trans }}</li>
                            <li>{{ 'complementary.tools.items.3'|trans }}</li>
                            <li>{{ 'complementary.tools.items.4'|trans }}</li>
                            <li>{{ 'complementary.tools.items.5'|trans }}</li>
                            <li>{{ 'complementary.tools.items.6'|trans }}</li>
                            <li>{{ 'complementary.tools.items.7'|trans }}</li>
                            <li>{{ 'complementary.tools.items.8'|trans }}</li>
                            <li>{{ 'complementary.tools.items.9'|trans }}</li>
                            <li>{{ 'complementary.tools.items.10'|trans }}</li>
                        </ul>
                    </div>

                    <div>
                        <h3>{{ 'complementary.contexts.title'|trans }}</h3>
                        <ul class="tag-list tag-list--large">
                            <li>{{ 'domains.media'|trans }}</li>
                            <li>{{ 'domains.finance'|trans }}</li>
                            <li>{{ 'domains.transport'|trans }}</li>
                            <li>{{ 'domains.retail'|trans }}</li>
                            <li>{{ 'domains.ecommerce'|trans }}</li>
                            <li>{{ 'domains.agriculture'|trans }}</li>
                            <li>{{ 'domains.healthcare'|trans }}</li>
                            <li>{{ 'domains.digital_marketing'|trans }}</li>
                            <li>{{ 'domains.internal_tools'|trans }}</li>
                            <li>{{ 'domains.business_platforms'|trans }}</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="content-section" aria-labelledby="skills-summary-title">
            <div class="card card--accent skills-panel skills-summary">
                <div class="skills-panel__intro">
                    <p class="eyebrow">{{ 'sections.summary.eyebrow'|trans }}</p>

                    <h2 id="skills-summary-title">{{ 'sections.summary.title'|trans }}</h2>
                </div>

                <p>{{ 'sections.summary.paragraph_1'|trans|highlight_keywords }}</p>
                <p>{{ 'sections.summary.paragraph_2'|trans|highlight_keywords }}</p>
                <p>{{ 'sections.summary.paragraph_3'|trans|highlight_keywords }}</p>

                <div class="buttons">
                    <a href="{{ path('app_contact', { _locale: app.request.locale }) }}" class="button">
                        {{ 'sections.summary.actions.contact'|trans }}
                    </a>

                    <a href="{{ path('app_projects_index', { _locale: app.request.locale }) }}" class="button button-secondary">
                        {{ 'sections.summary.actions.projects'|trans }}
                    </a>
                </div>
            </div>
        </section>
    </main>
{% endblock %}
