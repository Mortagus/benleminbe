{% extends 'private/base.html.twig' %}

{% block title %}Connexion privée{% endblock %}

{% block body_class %} private-shell--auth{% endblock %}

{% block private_header %}{% endblock %}

{% block universe_navigation %}{% endblock %}

{% block page_class %} private-page-shell--auth{% endblock %}

{% block body %}
    <section class="private-login-panel">
        <header class="private-page__header private-page__header--stacked">
            <div class="private-page__title">
                <p class="private-eyebrow">Zone protégée</p>
                <h1>Connexion privée</h1>
                <p class="private-page__lead">Accès réservé à l'espace d'administration personnel.</p>
            </div>
        </header>

        {% if app.request.query.get('expired') %}
            <p class="private-alert" role="alert">La session privée a expiré. Reconnectez-vous.</p>
        {% endif %}

        <section
            class="private-section-card"
            data-private-webauthn-login
            data-options-url="{{ path('app_private_security_passkeys_login_options') }}"
            data-result-url="{{ path('app_private_security_passkeys_login') }}"
        >
            <header class="private-section-card__header">
                <div>
                    <h2>Connexion par passkey</h2>
                    <p class="private-muted">La méthode recommandée. Utilise Windows Hello, Face ID, Touch ID ou une clé FIDO2.</p>
                </div>
            </header>

            <div class="private-actions">
                <button type="button" class="private-link-button" data-private-webauthn-login-button>
                    Se connecter avec une passkey
                </button>
            </div>

            <p class="private-muted" data-private-webauthn-login-status hidden></p>
        </section>

        {% if error %}
            <p class="private-alert" role="alert">Identifiants invalides.</p>
        {% endif %}

        <form class="private-form" method="post" action="{{ path('app_private_login') }}">
            <label class="private-form__field">
                <span>Utilisateur</span>
                <input
                    id="username"
                    type="text"
                    name="_username"
                    value="{{ lastUsername }}"
                    autocomplete="username"
                    required
                    autofocus
                >
            </label>

            <label class="private-form__field">
                <span>Mot de passe</span>
                <input
                    id="password"
                    type="password"
                    name="_password"
                    autocomplete="current-password"
                    required
                >
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit">Se connecter</button>
        </form>
    </section>
{% endblock %}
