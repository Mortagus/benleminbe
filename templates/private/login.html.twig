{% extends 'private/base.html.twig' %}

{% block title %}Connexion privée{% endblock %}

{% block body_class %} private-shell--auth{% endblock %}

{% block private_header %}{% endblock %}

{% block universe_navigation %}{% endblock %}

{% block page_class %} private-page-shell--auth{% endblock %}

{% block body %}
    <section class="private-login-panel">
        <header class="private-page__header private-page__header--stacked">
            <div class="private-page__title">
                <p class="private-eyebrow">Zone protégée</p>
                <h1>Connexion privée</h1>
                <p class="private-page__lead">Accès réservé à l'espace d'administration personnel.</p>
            </div>
        </header>

        {% if error %}
            <p class="private-alert" role="alert">Identifiants invalides.</p>
        {% endif %}

        <form class="private-form" method="post" action="{{ path('app_private_login') }}">
            <label class="private-form__field">
                <span>Utilisateur</span>
                <input
                    id="username"
                    type="text"
                    name="_username"
                    value="{{ lastUsername }}"
                    autocomplete="username"
                    required
                    autofocus
                >
            </label>

            <label class="private-form__field">
                <span>Mot de passe</span>
                <input
                    id="password"
                    type="password"
                    name="_password"
                    autocomplete="current-password"
                    required
                >
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit">Se connecter</button>
        </form>
    </section>
{% endblock %}
