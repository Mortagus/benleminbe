{% extends 'private/base.html.twig' %}

{% block title %}Albums{% endblock %}

{% block body %}
    <section class="private-page">
        <header class="private-page__header">
            <div class="private-page__title">
                <p class="private-eyebrow">Musique</p>
                <h1>Albums</h1>
                <p class="private-page__lead">
                    L écran album reste reporté tant que la couverture des métadonnées n est pas assez fiable.
                </p>
            </div>

            <div class="private-page__actions">
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_music_index') }}">Retour au module</a>
            </div>
        </header>

        <section class="private-surface">
            <header class="private-surface__header">
                <h2>État de la couverture</h2>
            </header>

            <div class="private-copy">
                {% if albums_available %}
                    <p>{{ albums_total }} album{{ albums_total > 1 ? 's' : '' }} distinct{{ albums_total > 1 ? 's' : '' }} ont été identifiés, mais la vue détaillée n est pas encore activée pour ce lot.</p>
                    <p>Le module restera prudent sur les albums tant que la correspondance depuis l archive Spotify ne sera pas plus solide.</p>
                {% else %}
                    <p>Aucune couverture album suffisamment fiable n est disponible pour l instant.</p>
                    <p>La liste album sera activée plus tard, après une stratégie d enrichissement validée et documentée.</p>
                {% endif %}
            </div>
        </section>
    </section>
{% endblock %}
