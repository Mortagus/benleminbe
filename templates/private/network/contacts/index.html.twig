{% extends 'private/base.html.twig' %}

{% block title %}Contacts{% endblock %}

{% block body %}
    <section class="private-page">
        <header class="private-page__header">
            <div class="private-page__title">
                <p class="private-eyebrow">Outil privé</p>
                <h1>Contacts</h1>
                <p class="private-page__lead">
                    Carnet centralisé des contacts à suivre, avec priorités, relation et prochaine action.
                </p>
            </div>

            <div class="private-page__actions">
                <a class="private-link-button" href="{{ path('app_private_network_contact_new') }}">Ajouter un contact</a>
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_index') }}">Retour au réseau</a>
            </div>
        </header>

        <section class="private-surface">
            <form class="private-toolbar private-toolbar--compact" method="get" action="{{ path('app_private_network_contacts') }}">
                <input type="hidden" name="page" value="1">

                <label class="private-toolbar__field private-toolbar__field--search">
                    <span>Recherche</span>
                    <input class="private-input" type="search" name="q" value="{{ currentQuery }}" placeholder="Nom, société, note..." />
                </label>

                <label class="private-toolbar__field">
                    <span>Priorité</span>
                    <select name="priority">
                        <option value="">Toutes</option>
                        {% for value, label in priorityOptions %}
                            <option value="{{ value }}" {{ currentPriority == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Relation</span>
                    <select name="relationship_status">
                        <option value="">Toutes</option>
                        {% for value, label in relationOptions %}
                            <option value="{{ value }}" {{ currentRelationStatus == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <div class="private-toolbar__actions">
                    <button class="private-link-button" type="submit">Filtrer</button>
                    {% if currentQuery or currentPriority or currentRelationStatus %}
                        <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_contacts') }}">Réinitialiser</a>
                    {% endif %}
                </div>
            </form>
        </section>

        {% if contacts is not empty %}
            <section class="private-surface">
                <header class="private-surface__header">
                    <div>
                        <h2>Liste des contacts</h2>
                        <p class="private-muted">
                            Affichage {{ visibleFrom }}-{{ visibleTo }} sur {{ totalContacts }} contact{{ totalContacts > 1 ? 's' : '' }}.
                        </p>
                    </div>
                </header>

                <div class="private-table-wrap">
                    <table class="private-table private-table--responsive">
                        <thead>
                            <tr>
                                <th>Contact</th>
                                <th>Entreprise</th>
                                <th>Priorité</th>
                                <th>Relation</th>
                                <th>Dernier contact</th>
                                <th>Prochaine action</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for contact in contacts %}
                                <tr data-contact-row data-contact-url="{{ path('app_private_network_contact_show', { id: contact.id }) }}">
                                    <td class="private-table__cell private-table__cell--main" data-label="Contact">
                                        <strong>
                                            <a class="private-table__contact-link" href="{{ path('app_private_network_contact_show', { id: contact.id }) }}">
                                                {{ contact.display_name }}
                                            </a>
                                        </strong>
                                        <div class="private-muted">
                                            {% if contact.role %}
                                                {{ contact.role }}
                                            {% else %}
                                                Aucun rôle renseigné
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td class="private-table__cell private-table__cell--hide-mobile" data-label="Entreprise">{{ contact.organization ?: 'Sans entreprise renseignée' }}</td>
                                    <td class="private-table__cell private-table__cell--badge" data-label="Priorité"><span class="private-badge private-badge--secondary">{{ contact.priority_label }}</span></td>
                                    <td class="private-table__cell private-table__cell--badge" data-label="Relation"><span class="private-badge">{{ contact.relationship_status_label }}</span></td>
                                    <td class="private-table__cell private-table__cell--hide-mobile" data-label="Dernier contact">
                                        {% if contact.last_contact_at %}
                                            {{ contact.last_contact_at|date('d/m/Y') }}
                                        {% else %}
                                            <span class="private-muted">Jamais</span>
                                        {% endif %}
                                    </td>
                                    <td class="private-table__cell private-table__cell--hide-mobile" data-label="Prochaine action">
                                        {% if contact.next_action %}
                                            {{ contact.next_action }}
                                            {% if contact.next_action_at %}
                                                <div class="private-muted">{{ contact.next_action_at|date('d/m/Y') }}</div>
                                            {% endif %}
                                        {% else %}
                                            <span class="private-muted">Aucune</span>
                                        {% endif %}
                                    </td>
                                    <td class="private-table__cell private-table__cell--actions private-actions private-actions--inline" data-label="Actions">
                                        <a
                                            class="private-icon-button"
                                            href="{{ path('app_private_network_contact_show', { id: contact.id }) }}"
                                            aria-label="Voir {{ contact.display_name }}"
                                            title="Voir {{ contact.display_name }}"
                                        >
                                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"></path>
                                                <circle cx="12" cy="12" r="3.25"></circle>
                                            </svg>
                                        </a>

                                        <form method="post" action="{{ path('app_private_network_contact_delete', { id: contact.id }) }}" onsubmit="return confirm('Supprimer {{ contact.display_name|e('js') }} ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('private-network-contact-delete-' ~ contact.id) }}">
                                            <input type="hidden" name="q" value="{{ currentQuery }}">
                                            <input type="hidden" name="priority" value="{{ currentPriority }}">
                                            <input type="hidden" name="relationship_status" value="{{ currentRelationStatus }}">
                                            <input type="hidden" name="page" value="{{ currentPage }}">
                                            <button
                                                class="private-icon-button private-icon-button--danger"
                                                type="submit"
                                                aria-label="Supprimer {{ contact.display_name }}"
                                                title="Supprimer {{ contact.display_name }}"
                                            >
                                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                    <path d="M4 7h16"></path>
                                                    <path d="M10 11v6"></path>
                                                    <path d="M14 11v6"></path>
                                                    <path d="M6 7l1 12h10l1-12"></path>
                                                    <path d="M9 7V4h6v3"></path>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if hasMore %}
                    <div class="private-actions private-actions--inline private-table-footer">
                        <a
                            class="private-link-button private-link-button--secondary"
                            href="{{ path('app_private_network_contacts', app.request.query.all|merge({ page: nextPage })) }}"
                        >
                            Charger plus
                        </a>
                    </div>
                {% endif %}
            </section>
        {% else %}
            <section class="private-surface">
                <p class="private-empty">Aucun contact enregistré.</p>
            </section>
        {% endif %}
    </section>
{% endblock %}
