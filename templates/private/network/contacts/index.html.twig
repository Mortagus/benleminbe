{% extends 'private/base.html.twig' %}

{% block title %}Contacts{% endblock %}

{% block body %}
    <section class="private-page">
        <header class="private-page__header">
            <div class="private-page__title">
                <p class="private-eyebrow">Outil privé</p>
                <h1>Contacts</h1>
                <p class="private-page__lead">
                    Carnet centralisé des contacts à suivre, avec priorités, relation et prochaine action.
                </p>
            </div>

            <div class="private-page__actions">
                <a class="private-link-button" href="{{ path('app_private_network_contact_new') }}">Ajouter un contact</a>
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_contact_merge_reviews_index') }}">Revue manuelle</a>
                <form class="private-inline-form" method="post" action="{{ path('app_private_network_contacts_merge_duplicates') }}" data-private-confirm="Fusionner automatiquement les doublons détectés ?">
                    <input type="hidden" name="_token" value="{{ csrf_token('private-network-contacts-merge-duplicates') }}">
                    <input type="hidden" name="q" value="{{ currentQuery }}">
                    <input type="hidden" name="priority" value="{{ currentPriority }}">
                    <input type="hidden" name="relationship_status" value="{{ currentRelationStatus }}">
                    <input type="hidden" name="organization_state" value="{{ currentOrganizationState }}">
                    <input type="hidden" name="role_state" value="{{ currentRoleState }}">
                    <input type="hidden" name="role" value="{{ currentRole }}">
                    <input type="hidden" name="role_category" value="{{ currentRoleCategory }}">
                    <input type="hidden" name="letter" value="{{ currentLetter }}">
                    <input type="hidden" name="sort" value="{{ currentSort }}">
                    <button class="private-link-button private-link-button--secondary" type="submit">Fusionner les doublons</button>
                </form>
                <form class="private-inline-form" method="post" action="{{ path('app_private_network_contact_merge_reviews_reset') }}" data-private-confirm="Tout réinitialiser ? Cela supprimera les contacts, interactions, imports et doublons." data-private-progress-submit="Réinitialisation en cours…">
                    <input type="hidden" name="_token" value="{{ csrf_token('private-network-contact-merge-reviews-reset') }}">
                    <input type="hidden" name="organization_state" value="{{ currentOrganizationState }}">
                    <input type="hidden" name="letter" value="{{ currentLetter }}">
                    <button class="private-link-button private-link-button--danger" type="submit">Tout réinitialiser</button>
                </form>
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_index') }}">Retour au réseau</a>
            </div>
        </header>

        <section class="private-surface">
            <form class="private-toolbar private-toolbar--compact" method="get" action="{{ path('app_private_network_contacts') }}">
                <input type="hidden" name="page" value="1">
                <input type="hidden" name="letter" value="{{ currentLetter }}">

                <label class="private-toolbar__field private-toolbar__field--search">
                    <span>Recherche</span>
                    <input class="private-input" type="search" name="q" value="{{ currentQuery }}" placeholder="Nom, société, note..." />
                </label>

                <label class="private-toolbar__field">
                    <span>Entreprise</span>
                    <select name="organization_state">
                        {% for value, label in organizationStateOptions %}
                            <option value="{{ value }}" {{ currentOrganizationState == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Rôle</span>
                    <select name="role_state">
                        {% for value, label in roleStateOptions %}
                            <option value="{{ value }}" {{ currentRoleState == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Rôle précis</span>
                    <select name="role">
                        {% for value, label in roleOptions %}
                            <option value="{{ value }}" {{ currentRole == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Catégorie métier</span>
                    <select name="role_category">
                        {% for value, label in roleCategoryOptions %}
                            <option value="{{ value }}" {{ currentRoleCategory == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Trier par</span>
                    <select name="sort">
                        {% for value, label in sortOptions %}
                            <option value="{{ value }}" {{ currentSort == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Priorité</span>
                    <select name="priority">
                        <option value="">Toutes</option>
                        {% for value, label in priorityOptions %}
                            <option value="{{ value }}" {{ currentPriority == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="private-toolbar__field">
                    <span>Relation</span>
                    <select name="relationship_status">
                        <option value="">Toutes</option>
                        {% for value, label in relationOptions %}
                            <option value="{{ value }}" {{ currentRelationStatus == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <div class="private-toolbar__actions">
                    <button class="private-link-button" type="submit">Filtrer</button>
                    {% if currentQuery or currentPriority or currentRelationStatus or currentOrganizationState or currentRoleState or currentRole or currentRoleCategory or currentSort != 'default' %}
                        <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_contacts') }}">Réinitialiser</a>
                    {% endif %}
                </div>
            </form>
        </section>

        <section class="private-surface">
            <nav class="private-alpha-index" aria-label="Filtrer les contacts par lettre">
                <span class="private-alpha-index__label">Annuaire</span>

                {% for letter in letterOptions %}
                    <a
                        class="private-alpha-index__link{{ letter.active ? ' private-alpha-index__link--active' : '' }}"
                        href="{{ path('app_private_network_contacts', app.request.query.all|merge({ letter: letter.value, page: 1 })) }}"
                        {{ letter.active ? 'aria-current="true"' : '' }}
                    >
                        {{ letter.label }}
                    </a>
                {% endfor %}
            </nav>
        </section>

        {% if contacts is not empty %}
            <section class="private-surface">
                <header class="private-surface__header">
                    <div>
                        <h2>Liste des contacts</h2>
                        <p class="private-muted">
                            Affichage {{ visibleFrom }}-{{ visibleTo }} sur {{ totalContacts }} contact{{ totalContacts > 1 ? 's' : '' }}.
                        </p>
                    </div>
                </header>

                <div class="private-table-wrap">
                    <table class="private-table private-table--responsive">
                        <thead>
                            <tr>
                                <th>Contact</th>
                                <th>Entreprise</th>
                                <th>Priorité</th>
                                <th>Relation</th>
                                <th>Dernier contact</th>
                                <th>Prochaine action</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for contact in contacts %}
                                <tr data-contact-row data-contact-url="{{ path('app_private_network_contact_show', { id: contact.id }) }}">
                                    <td class="private-table__cell private-table__cell--main" data-label="Contact">
                                        <strong>
                                            <a class="private-table__contact-link" href="{{ path('app_private_network_contact_show', { id: contact.id }) }}">
                                                {{ contact.display_name }}
                                            </a>
                                        </strong>
                                        <div class="private-muted">
                                            {% if contact.role %}
                                                {{ contact.role }}
                                            {% else %}
                                                Aucun rôle renseigné
                                            {% endif %}
                                        </div>
                                        <div class="private-muted">
                                            <span class="private-badge private-badge--secondary" title="{{ contact.role_category_rule ?: 'Classification déterministe' }}">
                                                {{ contact.role_category_label }}
                                            </span>
                                        </div>
                                    </td>
                                    <td class="private-table__cell private-table__cell--hide-mobile" data-label="Entreprise">{{ contact.organization ?: 'Sans entreprise renseignée' }}</td>
                                    <td class="private-table__cell private-table__cell--badge" data-label="Priorité"><span class="private-badge private-badge--secondary">{{ contact.priority_label }}</span></td>
                                    <td class="private-table__cell private-table__cell--badge" data-label="Relation"><span class="private-badge">{{ contact.relationship_status_label }}</span></td>
                                    <td class="private-table__cell private-table__cell--hide-mobile" data-label="Dernier contact">
                                        {% if contact.last_contact_at %}
                                            {{ contact.last_contact_at|date('d/m/Y') }}
                                        {% else %}
                                            <span class="private-muted">Jamais</span>
                                        {% endif %}
                                    </td>
                                    <td class="private-table__cell private-table__cell--hide-mobile" data-label="Prochaine action">
                                        {% if contact.next_action %}
                                            {{ contact.next_action }}
                                            {% if contact.next_action_at %}
                                                <div class="private-muted">{{ contact.next_action_at|date('d/m/Y') }}</div>
                                            {% endif %}
                                        {% else %}
                                            <span class="private-muted">Aucune</span>
                                        {% endif %}
                                    </td>
                                    <td class="private-table__cell private-table__cell--actions private-actions private-actions--inline" data-label="Actions">
                                        <a
                                            class="private-icon-button"
                                            href="{{ path('app_private_network_contact_show', { id: contact.id }) }}"
                                            aria-label="Voir {{ contact.display_name }}"
                                            title="Voir {{ contact.display_name }}"
                                        >
                                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"></path>
                                                <circle cx="12" cy="12" r="3.25"></circle>
                                            </svg>
                                        </a>

                                        <form method="post" action="{{ path('app_private_network_contact_delete', { id: contact.id }) }}" data-private-confirm="Supprimer {{ contact.display_name|e('js') }} ?">
                                            <input type="hidden" name="_token" value="{{ csrf_token('private-network-contact-delete-' ~ contact.id) }}">
                                            <input type="hidden" name="q" value="{{ currentQuery }}">
                                            <input type="hidden" name="priority" value="{{ currentPriority }}">
                                            <input type="hidden" name="relationship_status" value="{{ currentRelationStatus }}">
                                            <input type="hidden" name="organization_state" value="{{ currentOrganizationState }}">
                                            <input type="hidden" name="role_state" value="{{ currentRoleState }}">
                                            <input type="hidden" name="role" value="{{ currentRole }}">
                                            <input type="hidden" name="role_category" value="{{ currentRoleCategory }}">
                                            <input type="hidden" name="letter" value="{{ currentLetter }}">
                                            <input type="hidden" name="sort" value="{{ currentSort }}">
                                            <input type="hidden" name="page" value="{{ currentPage }}">
                                            <button
                                                class="private-icon-button private-icon-button--danger"
                                                type="submit"
                                                aria-label="Supprimer {{ contact.display_name }}"
                                                title="Supprimer {{ contact.display_name }}"
                                            >
                                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                    <path d="M4 7h16"></path>
                                                    <path d="M10 11v6"></path>
                                                    <path d="M14 11v6"></path>
                                                    <path d="M6 7l1 12h10l1-12"></path>
                                                    <path d="M9 7V4h6v3"></path>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if totalPages > 1 %}
                    <nav class="private-pagination" aria-label="Pagination des contacts">
                        <div class="private-pagination__controls">
                            {% if hasPrevious %}
                                <a
                                    class="private-pagination__link private-pagination__link--nav"
                                    href="{{ path('app_private_network_contacts', app.request.query.all|merge({ page: previousPage })) }}"
                                    rel="prev"
                                >
                                    Précédente
                                </a>
                            {% else %}
                                <span class="private-pagination__link private-pagination__link--nav private-pagination__link--disabled" aria-disabled="true">
                                    Précédente
                                </span>
                            {% endif %}

                            <div class="private-pagination__pages" aria-label="Pages">
                                {% for item in paginationPages %}
                                    {% if item.type == 'ellipsis' %}
                                        <span class="private-pagination__ellipsis" aria-hidden="true">…</span>
                                    {% else %}
                                        {% if item.current %}
                                            <span class="private-pagination__link private-pagination__link--current" aria-current="page">{{ item.label }}</span>
                                        {% else %}
                                            <a
                                                class="private-pagination__link"
                                                href="{{ path('app_private_network_contacts', app.request.query.all|merge({ page: item.page })) }}"
                                            >
                                                {{ item.label }}
                                            </a>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </div>

                            {% if hasNext %}
                                <a
                                    class="private-pagination__link private-pagination__link--nav"
                                    href="{{ path('app_private_network_contacts', app.request.query.all|merge({ page: nextPage })) }}"
                                    rel="next"
                                >
                                    Suivante
                                </a>
                            {% else %}
                                <span class="private-pagination__link private-pagination__link--nav private-pagination__link--disabled" aria-disabled="true">
                                    Suivante
                                </span>
                            {% endif %}
                        </div>
                    </nav>
                {% endif %}
            </section>
        {% else %}
            <section class="private-surface">
                <p class="private-empty">Aucun contact enregistré.</p>
            </section>
        {% endif %}
    </section>
{% endblock %}
