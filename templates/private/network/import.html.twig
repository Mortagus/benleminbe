{% extends 'private/base.html.twig' %}

{% block title %}Import de contacts{% endblock %}

{% block body %}
    <section class="private-page">
        <header class="private-page__header">
            <div class="private-page__title">
                <p class="private-eyebrow">Outil privé</p>
                <h1>Import</h1>
                <p class="private-page__lead">
                    Import vCard du téléphone ou export LinkedIn CSV, ou collage direct d'un contenu brut, pour alimenter la base de contacts.
                </p>
            </div>

            <div class="private-page__actions">
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_index') }}">Retour au réseau</a>
            </div>
        </header>

        {% if errors is not empty %}
            <div class="private-alert-list">
                {% for error in errors %}
                    <div class="private-alert">{{ error }}</div>
                {% endfor %}
            </div>
        {% endif %}

        <section class="private-surface">
            <header class="private-surface__header">
                <div>
                    <h2>Comment importer</h2>
                </div>
            </header>

            <div class="private-copy private-copy--intro">
                <p>Choisis la source d'import, puis envoie le fichier ou colle son contenu brut. Le script adéquat sera sélectionné automatiquement selon la source.</p>
                <p>Les champs utiles sont détectés automatiquement quand c'est possible. Les doublons sont fusionnés sur l'email, l'URL de profil ou le nom + entreprise.</p>
            </div>
        </section>

        <section class="private-surface">
            <header class="private-surface__header">
                <h2>Source d'import</h2>
            </header>

            <form class="private-form" method="post" action="{{ path('app_private_network_import') }}" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('private-network-import') }}">

                <div class="private-form__grid">
                    <label class="private-form__field private-form__field--wide">
                        <span>Source de l'import</span>
                        <select name="source_label">
                            {% for value, label in sourceOptions %}
                                <option value="{{ value }}" {{ values.source_label == value ? 'selected' : '' }}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </label>

                    <label class="private-form__field private-form__field--wide">
                        <span>Fichier</span>
                        <input type="file" name="file" accept=".csv,.vcf,.txt">
                    </label>

                    <label class="private-form__field private-form__field--wide">
                        <span>Contenu à coller</span>
                        <textarea name="content" rows="10" placeholder="Colle ici une vCard ou un CSV si tu n'utilises pas de fichier.">{{ values.content }}</textarea>
                    </label>
                </div>

                <div class="private-actions">
                    <button class="private-link-button" type="submit">Importer</button>
                </div>
            </form>
        </section>
    </section>
{% endblock %}
