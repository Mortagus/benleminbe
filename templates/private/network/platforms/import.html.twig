{% extends 'private/base.html.twig' %}

{% block title %}Importer des plateformes{% endblock %}

{% block body %}
    <section class="private-page">
        <header class="private-page__header">
            <div class="private-page__title">
                <p class="private-eyebrow">Plateformes</p>
                <h1>Importer des plateformes</h1>
                <p class="private-page__lead">
                    Restaure un snapshot JSON exporté depuis un autre environnement ou depuis cette instance après sauvegarde.
                </p>
            </div>

            <div class="private-page__actions">
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_platforms') }}">Retour aux plateformes</a>
            </div>
        </header>

        {% if errors is not empty %}
            <div class="private-alert-list">
                {% for error in errors %}
                    <div class="private-alert">{{ error }}</div>
                {% endfor %}
            </div>
        {% endif %}

        <section class="private-surface">
            <header class="private-surface__header">
                <h2>Fichier JSON</h2>
            </header>

            <div class="private-copy private-copy--intro">
                <p>Le fichier doit être un export de plateformes produit par cette interface. L’import remplace les plateformes existantes dans la base active.</p>
                <p>Le format contient un identifiant stable, un statut lisible, une note, une URL de profil et la date de dernière vérification.</p>
            </div>

            <form class="private-form" method="post" action="{{ path('app_private_network_platform_import') }}" enctype="multipart/form-data" data-private-confirm="Remplacer les plateformes existantes par ce fichier JSON ?">
                <input type="hidden" name="_token" value="{{ csrf_token('private-network-platform-import') }}">

                <div class="private-form__grid">
                    <label class="private-form__field private-form__field--wide">
                        <span>Fichier JSON</span>
                        <input type="file" name="file" accept=".json,application/json">
                    </label>
                </div>

                <div class="private-actions">
                    <button class="private-link-button" type="submit">Restaurer la sauvegarde</button>
                </div>
            </form>
        </section>
    </section>
{% endblock %}
