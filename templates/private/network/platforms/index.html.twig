{% extends 'private/base.html.twig' %}

{% block title %}Plateformes{% endblock %}

{% block body %}
    <section class="private-page">
        <header class="private-page__header">
            <div class="private-page__title">
                <p class="private-eyebrow">Outil privé</p>
                <h1>Plateformes</h1>
                <p class="private-page__lead">
                    Inventaire des profils à suivre, avec filtrage rapide, accès direct et date de vérification.
                </p>
            </div>

            <div class="private-page__actions">
                <a class="private-link-button" href="{{ path('app_private_network_platform_new') }}">Ajouter une plateforme</a>
                <a
                    class="private-icon-button"
                    href="{{ path('app_private_network_platform_import') }}"
                    aria-label="Importer une sauvegarde des plateformes"
                    title="Importer une sauvegarde des plateformes"
                >
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M12 4v12"></path>
                        <path d="m8 12 4 4 4-4"></path>
                        <path d="M5 20h14"></path>
                    </svg>
                </a>
                <a
                    class="private-icon-button"
                    href="{{ path('app_private_network_platform_export') }}"
                    aria-label="Exporter les plateformes"
                    title="Exporter les plateformes"
                >
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M12 20V8"></path>
                        <path d="m16 12-4-4-4 4"></path>
                        <path d="M5 4h14"></path>
                    </svg>
                </a>
                <a class="private-link-button private-link-button--secondary" href="{{ path('app_private_network_index') }}">Retour au réseau</a>
            </div>
        </header>

        {% if platforms is not empty %}
            <section class="private-surface">
                <header class="private-surface__header">
                    <h2>Liste des plateformes</h2>
                </header>

                <div class="private-platform-list">
                    {% for platform in platforms %}
                        <article class="private-platform-item">
                            <a
                                class="private-platform-item__link"
                                href="{{ path('app_private_network_platform_show', { slug: platform.slug }) }}"
                                aria-label="Voir la plateforme {{ platform.name }}"
                            ></a>

                            <div class="private-platform-item__main">
                                <div class="private-platform-item__heading">
                                    <strong>{{ platform.name }}</strong>
                                    <span class="private-badge private-platform-item__status">{{ platform.status_label }}</span>
                                </div>
                                <p class="private-muted private-platform-item__note">{{ platform.note ?: 'Aucune note' }}</p>
                            </div>

                            <div class="private-platform-item__field">
                                <span class="private-platform-item__label">Catégorie</span>
                                <span>{{ platform.category }}</span>
                            </div>

                            <div class="private-platform-item__field">
                                <span class="private-platform-item__label">Lien</span>
                                {% if platform.profile_url %}
                                    <a href="{{ platform.profile_url }}" target="_blank" rel="noopener noreferrer">Ouvrir</a>
                                {% else %}
                                    <span class="private-muted">À renseigner</span>
                                {% endif %}
                            </div>

                            <div class="private-platform-item__field">
                                <span class="private-platform-item__label">Dernière vérification</span>
                                {% if platform.last_reviewed_at %}
                                    <span>{{ platform.last_reviewed_at|date('d/m/Y') }}</span>
                                {% else %}
                                    <span class="private-muted">Jamais</span>
                                {% endif %}
                            </div>

                            <div class="private-platform-item__actions private-actions private-actions--inline">
                                <a href="{{ path('app_private_network_platform_show', { slug: platform.slug }) }}">Voir</a>
                                <a href="{{ path('app_private_network_platform_edit', { slug: platform.slug }) }}">Modifier</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </section>
        {% else %}
            <section class="private-surface">
                <p class="private-empty">Aucune plateforme enregistrée.</p>
            </section>
        {% endif %}
    </section>
{% endblock %}
