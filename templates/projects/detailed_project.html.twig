{# Projects - detailed_project.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}{{ projectData.meta_title }}{% endblock %}
{% block meta_description %}{{ projectData.lead }}{% endblock %}
{% block importmap %}{{ importmap(['app', 'page_project_detail']) }}{% endblock %}

{% block body %}
    <main class="project-detail-page">
        <section class="page-hero">
            <p class="eyebrow">{{ projectData.eyebrow }}</p>

            <h1>{{ projectData.title }}</h1>

            <p class="lead">
                {{ projectData.lead }}
            </p>

            {% if projectData.meta is defined and projectData.meta is not empty %}
                <ul class="meta-list">
                    {% for item in projectData.meta %}
                        <li>
                            <strong>{{ item.label }}</strong> {{ item.value }}
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </section>

        {% if associatedExperience is not null %}
            <section class="project-associated-experience">
                <p class="project-associated-experience__eyebrow">
                    {{ 'project.associated_experience.eyebrow'|trans({}, 'projects') }}
                </p>

                <h2>{{ associatedExperience.company }}</h2>

                <p>
                    {{ associatedExperience.role }} · {{ associatedExperience.period }}
                </p>

                <a href="{{ path('app_experiences_show', {
                    _locale: app.request.locale,
                    experience: associatedExperience.slug
                }) }}">
                    {{ 'project.associated_experience.link'|trans({}, 'projects') }}
                </a>
            </section>
        {% endif %}

        {% if projectData.sections is defined and projectData.sections is not empty %}
            <button class="content-toc-toggle"
                    type="button"
                    data-content-toc-toggle
                    aria-controls="project-toc"
                    aria-expanded="false">
                <span class="content-toc-toggle__icon" aria-hidden="true"></span>
                <span class="content-toc-toggle__label">{{ 'project.toc_title'|trans({}, 'projects') }}</span>
            </button>

            <nav id="project-toc" class="content-toc" data-content-toc aria-labelledby="project-toc-title">
                <h2 id="project-toc-title">{{ 'project.toc_title'|trans({}, 'projects') }}</h2>

                <ol>
                    {% for section in projectData.sections %}
                        <li>
                            <a href="#section-{{ loop.index }}">{{ section.title }}</a>
                        </li>
                    {% endfor %}
                </ol>
            </nav>

            {% for section in projectData.sections %}
                <section id="section-{{ loop.index }}" class="content-section{% if section.highlight is defined and section.highlight %} highlight-section{% endif %}">
                    <h2>{{ section.title }}</h2>

                    {% if section.paragraphs is defined %}
                        {% for paragraph in section.paragraphs %}
                            <p>{{ paragraph }}</p>
                        {% endfor %}
                    {% endif %}

                    {% if section.flow is defined %}
                        <div class="project-flow">
                            {% for step in section.flow %}
                                <div class="project-flow-step">{{ step }}</div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if section.list is defined %}
                        <ul>
                            {% for item in section.list %}
                                <li>{{ item }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if section.labeled_list is defined %}
                        <ul>
                            {% for item in section.labeled_list %}
                                <li>
                                    <strong>{{ item.label }}</strong> {{ item.text }}
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if section.groups is defined %}
                        <div class="tech-grid">
                            {% for group in section.groups %}
                                <div>
                                    <h3>{{ group.title }}</h3>

                                    {% if group.paragraphs is defined %}
                                        {% for paragraph in group.paragraphs %}
                                            <p>{{ paragraph }}</p>
                                        {% endfor %}
                                    {% endif %}

                                    {% if group.items is defined %}
                                        <ul>
                                            {% for item in group.items %}
                                                <li>{{ item }}</li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if section.subsections is defined %}
                        {% for subsection in section.subsections %}
                            <div class="project-subsection">
                                <h3>{{ subsection.title }}</h3>

                                {% if subsection.paragraphs is defined %}
                                    {% for paragraph in subsection.paragraphs %}
                                        <p>{{ paragraph }}</p>
                                    {% endfor %}
                                {% endif %}

                                {% if subsection.list is defined %}
                                    <ul>
                                        {% for item in subsection.list %}
                                            <li>{{ item }}</li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                </section>
            {% endfor %}
        {% endif %}

        <nav class="page-navigation" aria-label="{{ 'project.navigation_label'|trans({}, 'projects') }}">
            <a href="{{ path('app_projects_index', { _locale: app.request.locale }) }}" class="back-link">
                {{ projectData.back }}
            </a>

            {% if previousProject is not null %}
                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: previousProject.key }) }}" class="previous-link">
                    {{ 'project.previous'|trans({}, 'projects') }}
                </a>
            {% endif %}

            {% if nextProject is not null %}
                <a href="{{ path('app_projects_show', { _locale: app.request.locale, project: nextProject.key }) }}" class="next-link">
                    {{ 'project.next'|trans({}, 'projects') }}
                </a>
            {% endif %}
        </nav>
    </main>
{% endblock %}
