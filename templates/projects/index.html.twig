{% extends 'base.html.twig' %}

{% block title %}{{ 'index.meta_title'|trans({}, 'projects') }}{% endblock %}

{% block body %}
    <main class="projects-page">

        <section class="page-hero">
            <p class="eyebrow">{{ 'index.eyebrow'|trans({}, 'projects') }}</p>
            <h1>{{ 'index.title'|trans({}, 'projects') }}</h1>
            <p class="lead">{{ 'index.lead'|trans({}, 'projects') }}</p>
        </section>

        <section class="projects-list">

            {% for project in projects %}
                <a href="{{ path(project.route, { _locale: app.request.locale }) }}" class="project-card-link">
                    <article class="project-card">
                        <h2>{{ ('index.cards.' ~ project.key ~ '.title')|trans({}, 'projects') }}</h2>
                        <p>{{ ('index.cards.' ~ project.key ~ '.description')|trans({}, 'projects') }}</p>
                    </article>
                </a>
            {% endfor %}

        </section>

    </main>
{% endblock %}
