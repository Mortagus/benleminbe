{% extends 'base.html.twig' %}

{% block title %}{{ 'stanhome.meta_title'|trans({}, 'projects') }}{% endblock %}

{% block body %}
    <main class="project-detail-page">
        <section class="page-hero">
            <p class="eyebrow">{{ 'stanhome.eyebrow'|trans({}, 'projects') }}</p>

            <h1>{{ 'stanhome.title'|trans({}, 'projects') }}</h1>

            <p class="lead">
                {{ 'stanhome.lead'|trans({}, 'projects') }}
            </p>

            <ul class="meta-list">
                <li><strong>{{ 'stanhome.meta.period_label'|trans({}, 'projects') }}</strong> {{ 'stanhome.meta.period_value'|trans({}, 'projects') }}</li>
                <li><strong>{{ 'stanhome.meta.role_label'|trans({}, 'projects') }}</strong> {{ 'stanhome.meta.role_value'|trans({}, 'projects') }}</li>
                <li><strong>{{ 'stanhome.meta.mission_label'|trans({}, 'projects') }}</strong> {{ 'stanhome.meta.mission_value'|trans({}, 'projects') }}</li>
                <li><strong>{{ 'stanhome.meta.stack_label'|trans({}, 'projects') }}</strong> {{ 'stanhome.meta.stack_value'|trans({}, 'projects') }}</li>
            </ul>
        </section>

        <section class="content-section">
            <h2>{{ 'stanhome.context.title'|trans({}, 'projects') }}</h2>

            <p>{{ 'stanhome.context.p1'|trans({}, 'projects') }}</p>
            <p>{{ 'stanhome.context.p2'|trans({}, 'projects') }}</p>
        </section>

        <section class="content-section">
            <h2>{{ 'stanhome.role.title'|trans({}, 'projects') }}</h2>

            <p>{{ 'stanhome.role.p1'|trans({}, 'projects') }}</p>

            <ul>
                <li>{{ 'stanhome.role.li1'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.role.li2'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.role.li3'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.role.li4'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.role.li5'|trans({}, 'projects') }}</li>
            </ul>
        </section>

        <section class="content-section">
            <h2>{{ 'stanhome.tech.title'|trans({}, 'projects') }}</h2>

            <div class="tech-grid">
                <div>
                    <h3>{{ 'stanhome.tech.backend.title'|trans({}, 'projects') }}</h3>
                    <ul>
                        <li>PHP 7</li>
                        <li>Symfony 3.1</li>
                        <li>MariaDB</li>
                        <li>{{ 'stanhome.tech.backend.oop'|trans({}, 'projects') }}</li>
                        <li>{{ 'stanhome.tech.backend.solid'|trans({}, 'projects') }}</li>
                    </ul>
                </div>

                <div>
                    <h3>{{ 'stanhome.tech.api.title'|trans({}, 'projects') }}</h3>
                    <ul>
                        <li>REST APIs</li>
                        <li>Services SOAP</li>
                        <li>{{ 'stanhome.tech.api.integration'|trans({}, 'projects') }}</li>
                    </ul>
                </div>

                <div>
                    <h3>{{ 'stanhome.tech.quality.title'|trans({}, 'projects') }}</h3>
                    <ul>
                        <li>PHPUnit</li>
                        <li>Jasmine</li>
                        <li>CasperJS</li>
                        <li>{{ 'stanhome.tech.quality.reviews'|trans({}, 'projects') }}</li>
                        <li>GitLab CI/CD</li>
                    </ul>
                </div>

                <div>
                    <h3>{{ 'stanhome.tech.tools.title'|trans({}, 'projects') }}</h3>
                    <ul>
                        <li>GitLab</li>
                        <li>Docker</li>
                        <li>Jira</li>
                        <li>Confluence</li>
                        <li>Sentry</li>
                        <li>NPM, Gulp, Bower</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>{{ 'stanhome.process.title'|trans({}, 'projects') }}</h2>

            <p>{{ 'stanhome.process.p1'|trans({}, 'projects') }}</p>
            <p>{{ 'stanhome.process.p2'|trans({}, 'projects') }}</p>
            <p>{{ 'stanhome.process.p3'|trans({}, 'projects') }}</p>
        </section>

        <section class="content-section">
            <h2>{{ 'stanhome.challenges.title'|trans({}, 'projects') }}</h2>

            <ul>
                <li>{{ 'stanhome.challenges.li1_label'|trans({}, 'projects') }} {{ 'stanhome.challenges.li1'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.challenges.li2_label'|trans({}, 'projects') }} {{ 'stanhome.challenges.li2'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.challenges.li3_label'|trans({}, 'projects') }} {{ 'stanhome.challenges.li3'|trans({}, 'projects') }}</li>
                <li>{{ 'stanhome.challenges.li4_label'|trans({}, 'projects') }} {{ 'stanhome.challenges.li4'|trans({}, 'projects') }}</li>
            </ul>
        </section>

        <section class="content-section highlight-section">
            <h2>{{ 'stanhome.learning.title'|trans({}, 'projects') }}</h2>

            <p>{{ 'stanhome.learning.p1'|trans({}, 'projects') }}</p>
            <p>{{ 'stanhome.learning.p2'|trans({}, 'projects') }}</p>
        </section>

        <nav class="page-navigation" aria-label="Navigation entre les projets">
            <a href="{{ path('app_projects_index', { _locale: app.request.locale }) }}" class="back-link">
                {{ 'stanhome.back'|trans({}, 'projects') }}
            </a>
        </nav>
    </main>
{% endblock %}
