            label: 'navigation.index'|trans,
            active: currentRoute == 'app_games_index',
            aria_current: currentRoute == 'app_games_index',
        },
        {
            href: path('app_games_simon', { _locale: app.request.locale }),
            label: 'navigation.simon'|trans,
            active: currentRoute == 'app_games_simon',
            aria_current: currentRoute == 'app_games_simon',
        },
    ],
} only %}
